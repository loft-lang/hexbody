// fit — THE DOORSTEP GATE for features, arcs, levels and terrain (`K-FIT`, `I-QUANT`).
//
// `draft_fits` already gates the doorstep for the turtle form and one embedded run (`X60`).  The
// four parameters here had their quantisation MEASURED (`X48`, `X49`, `X58`, `X59`) and never
// REFUSED, so each was a silent-snap hole: author an off-grid value, and it round-trips as a
// DIFFERENT value with `ρ = 0` — success reported on a model nobody wrote.
//
// THE CONTRACT, taken from `X60` because it is the only one that cannot be gamed:
//
//     the doorstep accepts EXACTLY what round-trips.
//     0 disagreements  (it refuses something that would have worked)
//     0 false accepts  (it admits something that does not come back)
//
// Measured against the real behaviour, not against the formula the doorstep uses — otherwise the
// gate would only prove the code agrees with itself.
//
//   1  FEATURES — the admissible `t` is READ OFF the field, and `X48`'s formula is corrected
//   2  FEATURES — accepts exactly what recovers, and the refusal carries an offer + residual
//   3  ARCS — accepts exactly the realisable shells, and offers the nearest
//   4  LEVELS — measured to have nothing to refuse, and shown not to be a vacuous `true`
//   5  TERRAIN — the voxel's integer grid, now that the fork is closed
//   6  MATERIAL IDS — hexbody's wall slot is narrower than moros's, and overflow ERASES a wall
use hex_field;
use housedraw;
use hexarc;
use hexdraft;
use hexfit;
use hexseat;
use hexcombine;

const W  = 41;
const H  = 41;
const Q0 = -20;
const R0 = -20;

fn main() {
  ok = true;
  println("=== fit — the doorstep for features, arcs, levels and terrain ===");

  p = plan_new(0, 0, 5, 4, 0, false);
  cells = hexset_chunk(Q0, R0, W, H);
  lb = labels_new(Q0, R0, W, H);
  ncell = draw_floor(p, cells, lb, 9);

  // ── 1. THE ADMISSIBLE t IS READ OFF THE FIELD ─────────────────────────────
  //
  // `X48` recorded the grid as the edge centres `(2i+1)/2n`.  Measured, that holds for only ONE of
  // the two side families.  This section is the correction, and it is why `feature_grid` consults
  // `side_edges` instead of computing anything.
  println("");
  println("1. THE GRID — two families, and (2i+1)/2n is only one of them");
  println("   side  edges  lo          hi          step        uniform  == (2i+1)/2n");
  nuni = 0;
  nformula = 0;
  for side in 0..4 {
    g = feature_grid(p, cells, side);
    n = len(g);
    srt: vector<float> = [];
    for i in 0..n { srt += [g[i] ?? 0.0]; }
    for i2 in 0..n {
      for j in 0..n - 1 {
        if (srt[j] ?? 0.0) > (srt[j + 1] ?? 0.0) {
          sw = srt[j] ?? 0.0; srt[j] = srt[j + 1] ?? 0.0; srt[j + 1] = sw;
        }
      }
    }
    lo = srt[0] ?? 0.0;
    hi = srt[n - 1] ?? 0.0;
    step = (hi - lo) / ((n - 1) as float) ?? 0.0;
    uni = true;
    for k in 0..n {
      if abs((srt[k] ?? 0.0) - (lo + (k as float) * step)) > 1e-12 { uni = false; }
    }
    formula = true;
    for k2 in 0..n {
      if abs((srt[k2] ?? 0.0) - ((2.0 * (k2 as float) + 1.0) / (2.0 * (n as float)))) > 1e-12 {
        formula = false;
      }
    }
    if uni { nuni = nuni + 1; }
    if formula { nformula = nformula + 1; }
    println("   {side:>4}  {n:>5}  {lo:<10.7}  {hi:<10.7}  {step:<10.7}  {uni:<7}  {formula}");
  }
  println("   {nuni} of 4 sides uniformly spaced, {nformula} of 4 match (2i+1)/2n");
  if nuni != 4 {
    println("  FAIL: a side's edge centres are not uniformly spaced — the grid is not what"
            + " either family describes"); ok = false;
  }
  if nformula != 2 {
    println("  FAIL: expected exactly 2 of 4 sides to match (2i+1)/2n (the tiling family)."
            + " Got {nformula} — X48's correction no longer describes the field"); ok = false;
  }
  println("   => the INSET family spans exactly sqrt(3)/2 of its side, so (2i+1)/2n would refuse");
  println("      every legal position on it. `feature_grid` reads `side_edges` and cannot.");

  // ── 2. FEATURES — ACCEPTS EXACTLY WHAT RECOVERS ───────────────────────────
  //
  // The real contract.  For a dense sweep of authored `t`, compare the DOORSTEP's verdict against
  // what actually happens: place the opening and read back which edge got it.  A `t` recovers
  // exactly when the opened edge's own stored `t` IS the authored one.
  println("");
  println("2. FEATURES — the doorstep accepts exactly what recovers");
  ndis = 0;
  nfalse = 0;
  nacc = 0;
  ntried = 0;
  for side2 in 0..4 {
    g2 = feature_grid(p, cells, side2);
    n2 = len(g2);
    // every admissible t, and a dense sweep of inadmissible ones
    cand: vector<float> = [];
    for i3 in 0..n2 { cand += [g2[i3] ?? 0.0]; }
    for s in 0..41 { cand += [(s as float) / 40.0]; }
    for ci in 0..len(cand) {
      t = cand[ci] ?? 0.0;
      verdict = feature_fits(p, cells, side2, t, 1) == FIT_OK;
      // what actually happens
      eg = edgeset_new(Q0, R0, W, H);
      draw_walls(cells, eg, 3);
      place_opening(p, cells, eg, side2, t, 1, OPEN_DOOR);
      sr = side_edges(p, cells, side2);
      backt = -1.0;
      for ei in 0..side_run_len(sr) {
        if edge_mat(eg, sr.sr_qa[ei] ?? 0, sr.sr_ra[ei] ?? 0,
                    sr.sr_qb[ei] ?? 0, sr.sr_rb[ei] ?? 0) == OPEN_DOOR {
          backt = sr.sr_t[ei] ?? -1.0;
        }
      }
      recovers = backt == t;
      ntried = ntried + 1;
      if verdict { nacc = nacc + 1; }
      if verdict && !recovers { nfalse = nfalse + 1; }
      if !verdict && recovers { ndis = ndis + 1; }
    }
  }
  println("   {ntried} authored positions over 4 sides: {nacc} admitted");
  println("   FALSE ACCEPTS (admitted but does not recover): {nfalse}");
  println("   DISAGREEMENTS (refused but would have recovered): {ndis}");
  if nfalse != 0 {
    println("  FAIL: the doorstep admitted a t that snaps — the silent-snap hole is still open");
    ok = false;
  }
  if ndis != 0 {
    println("  FAIL: the doorstep refused a t that recovers exactly — it is over-refusing, which"
            + " makes legal models unauthorable"); ok = false;
  }
  // CONTROL: the sweep must contain both kinds, or 0/0 proves nothing.
  if nacc <= 0 || nacc >= ntried {
    println("  FAIL: the sweep is all-accept or all-refuse ({nacc} of {ntried}) — 0 false accepts"
            + " and 0 disagreements would be vacuous"); ok = false;
  }
  println("   CONTROL the sweep contains both: {nacc} admitted, {ntried - nacc} refused");

  // the refusal owes an OFFER and a RESIDUAL (`K-FIT`)
  println("");
  println("   the refusal's OFFER — a raw position, the legal one it maps to, the residual:");
  nbadoffer = 0;
  for want in [0.0, 0.13, 0.37, 0.5, 0.61, 0.88, 1.0] {
    off = feature_fit_t(p, cells, 0, want);
    res = feature_fit_residual(p, cells, 0, want);
    good = feature_fits(p, cells, 0, off, 1) == FIT_OK;
    if !good { nbadoffer = nbadoffer + 1; }
    println("   t {want:<5} -> offer {off:<20} residual {res:<22} the offer itself fits {good}");
  }
  if nbadoffer != 0 {
    println("  FAIL: an offer was itself inadmissible — a blank no would be more honest"); ok = false;
  }
  println("   named reason for an off-grid t: \"{fit_reason(feature_fits(p, cells, 0, 0.37, 1))}\"");
  if feature_fits(p, cells, 0, 0.37, 1) == FIT_OK {
    println("  FAIL: 0.37 is on the grid, so the reason above tested nothing"); ok = false;
  }
  // the span restriction, and a side that carries no edges
  println("   a 0-edge feature: {fit_reason(feature_fits(p, cells, 0, 0.5, 0))}");
  println("   a 99-edge feature: {fit_reason(feature_fits(p, cells, 0, 0.5, 99))}");
  println("   a non-side: {fit_reason(feature_fits(p, cells, 9, 0.5, 1))}");
  if feature_fits(p, cells, 0, 0.5, 0) != FIT_BAD_SPAN
     || feature_fits(p, cells, 0, 0.5, 99) != FIT_BAD_SPAN
     || feature_fits(p, cells, 9, 0.5, 1) != FIT_NO_SIDE {
    println("  FAIL: a span or side restriction is not named"); ok = false;
  }

  // ── 3. ARCS — ACCEPTS EXACTLY THE REALISABLE SHELLS ───────────────────────
  //
  // `X49`: a radius between two shells draws the disk of the shell BELOW it, so it round-trips as a
  // different model with rho = 0.  Same contract: verdict vs what actually happens.
  println("");
  println("3. ARCS — the doorstep accepts exactly the realisable shells");
  adis = 0;
  afalse = 0;
  aacc = 0;
  for n24 in 0..65 {
    verdict2 = arc_fits(n24) == FIT_OK;
    dk = hexset_chunk(Q0, R0, W, H);
    arc_fill(0, 0, n24, dk);
    recovers2 = arc_shell_max(dk, 0, 0) == n24;
    if verdict2 { aacc = aacc + 1; }
    if verdict2 && !recovers2 { afalse = afalse + 1; }
    if !verdict2 && recovers2 { adis = adis + 1; }
  }
  println("   radii 0..64: {aacc} admitted, {afalse} false accepts, {adis} disagreements");
  if afalse != 0 || adis != 0 {
    println("  FAIL: the arc doorstep does not match what the field distinguishes"); ok = false;
  }
  if aacc <= 0 || aacc >= 65 {
    println("  FAIL: all or nothing admitted — the comparison is vacuous"); ok = false;
  }
  println("   the OFFER — a raw radius, the shell it maps to, the residual:");
  nbad2 = 0;
  for wr in [5, 11, 13, 20, 37, 40, 60] {
    o2 = arc_fit_n(wr);
    if arc_fits(o2) != FIT_OK { nbad2 = nbad2 + 1; }
    println("   N {wr:>2} -> shell {o2:>2}, residual {arc_fit_residual(wr)}");
  }
  if nbad2 != 0 {
    println("  FAIL: an arc offer was itself not a shell"); ok = false;
  }
  println("   named reason: \"{fit_reason(arc_fits(20))}\"");

  // ── 4. LEVELS — NOTHING TO REFUSE, AND NOT A VACUOUS TRUE ─────────────────
  //
  // A level is an integer index used as a filter before the cut (`X58`), so nothing exists BETWEEN
  // two levels to be snapped.  `level_fits` therefore returns OK always — which is a result, not an
  // omission.  It is kept honest by the only thing that can keep an always-true predicate honest:
  // the SAME doorstep must refuse the other parameters, so "accepts every level" is a statement
  // about levels and not about the checker.
  println("");
  println("4. LEVELS — measured to have nothing to refuse");
  a = hexset_chunk(Q0, R0, W, H);
  b = hexset_chunk(Q0, R0, W, H);
  for lr in 0..3 { for lq in 0..3 { hexset_set(a, lq, lr, true); } }
  for lr2 in 2..5 { for lq2 in 2..5 { hexset_set(b, lq2, lr2, true); } }
  nlv = 0;
  nsame0 = -1;
  ndiff0 = -1;
  same_all = true;
  for lv in [-1000000, -999, -7, -1, 0, 1, 7, 999, 1000000] {
    e1 = edgeset_new(Q0, R0, W, H);
    ns = combine_cut_level(a, lv, 1, b, lv, 2, lv, e1);
    e2 = edgeset_new(Q0, R0, W, H);
    nd = combine_cut_level(a, lv, 1, b, lv + 1, 2, lv, e2);
    if nsame0 < 0 { nsame0 = ns; ndiff0 = nd; }
    if ns != nsame0 || nd != ndiff0 { same_all = false; }
    if level_fits(lv) == FIT_OK { nlv = nlv + 1; }
  }
  println("   9 levels across the integer range: {nlv} admitted, behaviour identical at every"
          + " one: {same_all} (same-level {nsame0} edges, different-level {ndiff0})");
  if nlv != 9 {
    println("  FAIL: a level was refused, but nothing distinguishes one integer from another");
    ok = false;
  }
  if !same_all {
    println("  FAIL: behaviour varies with the level integer — then there IS something to refuse"
            + " and `level_fits` is wrong to accept everything"); ok = false;
  }
  // THE CONTROL that makes "accepts everything" non-vacuous: the same doorstep refuses elsewhere.
  refuses = feature_fits(p, cells, 0, 0.37, 1) != FIT_OK && arc_fits(20) != FIT_OK;
  println("   CONTROL the same doorstep still refuses a bad t and a bad shell: {refuses}");
  if !refuses {
    println("  FAIL: the doorstep accepts everything, so 'levels have nothing to refuse' is a"
            + " statement about the checker, not about levels"); ok = false;
  }

  // ── 5. TERRAIN — THE VOXEL'S GRID, AND THE FORK NOW CLOSED ───────────────
  //
  // THE DECISION (user, 2026-07-24): *"I will never want to add more world information than in the
  // limited moros voxels."*  So moros's `Hex` is the storage of record, `h_height` is an INTEGER,
  // and the quantum is moros's own `HEIGHT_SCALE = 0.25` wu.
  //
  // The gate cannot lean on hexbody's f64 storage to show this — that slot keeps everything, which
  // is exactly why the hole was silent.  So it rounds through the VOXEL: `h_height` as an integer,
  // read back as `units * HEIGHT_SCALE`.  Off-grid must NOT survive; on-grid must.
  println("");
  println("5. TERRAIN — the doorstep accepts exactly what survives the VOXEL");
  println("   the voxel grid: 1 unit = {HEIGHT_SCALE} wu = {HEIGHT_SCALE * 0.866} m,"
          + " a storey = 12 units = {height_from_units(12)} wu");
  zdis = 0;
  zfalse = 0;
  zacc = 0;
  ztot = 0;
  for zi in 0..81 {
    z = (zi as float) * 0.0625;                     // quarter-steps AND the halves between them
    verdict3 = seat_fits(z) == FIT_OK;
    // the voxel round trip: what h_height would hold, read back
    survives = height_from_units(height_units(z)) == z;
    ztot = ztot + 1;
    if verdict3 { zacc = zacc + 1; }
    if verdict3 && !survives { zfalse = zfalse + 1; }
    if !verdict3 && survives { zdis = zdis + 1; }
  }
  println("   {ztot} heights swept: {zacc} admitted, {zfalse} false accepts, {zdis} disagreements");
  if zfalse != 0 || zdis != 0 {
    println("  FAIL: the height doorstep does not match what the voxel keeps"); ok = false;
  }
  if zacc <= 0 || zacc >= ztot {
    println("  FAIL: all or nothing admitted — the sweep proves nothing"); ok = false;
  }
  println("   CONTROL the sweep contains both: {zacc} admitted, {ztot - zacc} refused");
  println("   the OFFER — a raw height, the voxel height it maps to, the residual:");
  nbadz = 0;
  for wz in [0.1, 0.375, 1.125, 2.54, 3.0] {
    oz = seat_fit_z(wz);
    if seat_fits(oz) != FIT_OK { nbadz = nbadz + 1; }
    println("   z {wz:<6} -> {oz:<7} ({height_units(wz)} units), residual"
            + " {seat_fit_residual(wz):<8} = {seat_fit_residual(wz) * 0.866} m");
  }
  if nbadz != 0 {
    println("  FAIL: a height offer was itself off the voxel grid"); ok = false;
  }
  println("   named reason: \"{fit_reason(seat_fits(1.125))}\"");

  // WHAT THE DECISION COSTS hexbody today — priced, so the cost is a number and not a worry.
  terr = heights_new(Q0, R0, W, H);
  fp = hexset_chunk(Q0, R0, W, H);
  for tr in 0..4 {
    for tq in 0..4 {
      hexset_set(fp, tq, tr, true);
      height_set(terr, tq, tr, 0.75 * (tq as float));
    }
  }
  nong = 0;
  println("   the SEAT policies against the voxel grid:");
  for pol in [SEAT_LOW, SEAT_MEAN, SEAT_HIGH] {
    zz = seat_height(fp, terr, pol);
    fitsz = seat_fits(zz) == FIT_OK;
    if fitsz { nong = nong + 1; }
    println("   policy {pol}: seat {zz:<7} = {zz / HEIGHT_SCALE ?? 0.0} units, fits {fitsz},"
            + " offer {seat_fit_z(zz)}");
  }
  println("   => {nong} of 3 policies land on the grid; SEAT_MEAN lands exactly HALF a unit off,"
          + " so it is refused with an offer rather than truncated silently");
  if nong == 3 {
    println("  FAIL: every policy is on-grid, so the doorstep is describing a problem that does"
            + " not exist"); ok = false;
  }
  // and the roof, the other producer of heights
  rc = hexset_chunk(Q0, R0, W, H);
  draw_floor(p, rc, labels_new(Q0, R0, W, H), 9);
  rh = heights_new(Q0, R0, W, H);
  draw_roof(p, rc, rh, 2.54, 1.0, 0);
  roff = 0;
  rtot = 0;
  rworst = 0.0;
  for rr3 in R0..R0 + H {
    for rq3 in Q0..Q0 + W {
      if hexset_get(rc, rq3, rr3) {
        rz = height_get(rh, rq3, rr3);
        rtot = rtot + 1;
        if seat_fits(rz) != FIT_OK {
          roff = roff + 1;
          if seat_fit_residual(rz) > rworst { rworst = seat_fit_residual(rz); }
        }
      }
    }
  }
  println("   the ROOF (eave 2.54, pitch 1.0): {roff} of {rtot} heights off the grid,"
          + " worst residual {rworst} wu = {rworst * 0.866} m");
  if roff <= 0 {
    println("  FAIL: the roof is entirely on-grid, so it cannot show what the decision costs");
    ok = false;
  }

  // ── 6. MATERIAL IDS — NARROWER THAN moros, AND SILENT DELETION ───────────
  //
  // The rule is never to carry MORE information than the voxel holds; hexbody's wall slot holds
  // LESS — `EdgeSet.eg_mat` is a `u8` where moros's `h_wall_n` is an integer.  Being narrower is
  // allowed; DELETING a wall silently is not.
  println("");
  println("6. MATERIAL IDS — hexbody's wall slot is a u8, and overflow ERASES the wall");
  mdis = 0;
  mfalse = 0;
  macc = 0;
  for m in [1, 2, 100, 200, 254, 255, 256, 257, 300, 70000] {
    verdict4 = mat_fits(m) == FIT_OK;
    me = edgeset_new(Q0, R0, W, H);
    edge_set_mat(me, 1, 1, nb_q(1, 1, 0), nb_r(1, 1, 0), m);
    kept = edge_mat(me, 1, 1, nb_q(1, 1, 0), nb_r(1, 1, 0)) == m;
    if verdict4 { macc = macc + 1; }
    if verdict4 && !kept { mfalse = mfalse + 1; }
    if !verdict4 && kept { mdis = mdis + 1; }
  }
  println("   10 material ids: {macc} admitted, {mfalse} false accepts, {mdis} disagreements");
  if mfalse != 0 || mdis != 0 {
    println("  FAIL: the material doorstep does not match what the slot keeps"); ok = false;
  }
  // THE CONTROL: 256 must really vanish, or the bound is imaginary.
  ce = edgeset_new(Q0, R0, W, H);
  edge_set_mat(ce, 1, 1, nb_q(1, 1, 0), nb_r(1, 1, 0), 256);
  gone = edge_mat(ce, 1, 1, nb_q(1, 1, 0), nb_r(1, 1, 0));
  println("   CONTROL material 256 reads back as {gone} (0 = NO WALL, silent deletion)");
  if gone != 0 {
    println("  FAIL: 256 survived, so MAT_MAX is not the real bound and the refusal is wrong");
    ok = false;
  }
  println("   named reason: \"{fit_reason(mat_fits(256))}\"");
  println("   ⚠ NO OFFER is made: a material id is NOMINAL, not ordinal. 255 is not 'nearly 256',");
  println("      it is a different material — offering it would look like a small correction.");

  println("");
  if ok { println("=== FIT OK ==="); }
  else { println("=== FIT BROKEN ==="); }
}
