// trip — THE ROUND-TRIP GATE (`rt_trip`), STEP S7.  WRITTEN BEFORE `rebuild` EXISTS.
//
//     for every entry:   write(rebuild(draw(read(T))))  ==  T     byte-for-byte   (P3/P4)
//     for every pair:    f(a) != f(b)                             law F
//
// It is RED on purpose until S8 lands `rebuild`, and `tools/run_tests.sh` ASSERTS that redness —
// so the gate runs on every `make test` (it cannot rot), and if it ever goes green by accident
// the runner FAILS and demands the row be promoted.  Red for the stated reason, never red because
// it crashed.
//
// THE CORPUS IS READ, NEVER REGENERATED (`DESIGN.md` §8.0).  `src/corpusgen.loft` wrote these
// bytes once and they are committed; a gate that regenerates its own baseline compares new output
// against new output and passes unconditionally.  Everything below reads the committed files.
//
//   1  every committed T round-trips through read/write BYTE-FOR-BYTE
//   2  draw(read(T)) still digests to the committed .f — the regression anchor
//   3  law F over the corpus: no two entries share a field
//   4  the full trip — needs `rebuild`, so RED until S8
use hex_field;
use hexform;
use formcensus;
use formtext;
use formfit;

const W = 61;
const H = 61;
const Q0 = -30;
const R0 = -30;

fn main() {
  ok = true;
  println("=== rt_trip — the round trip, against the committed corpus ===");

  // Every committed level, so raising `formfit::LEVEL` without extending the corpus — or the
  // reverse — fails here rather than passing quietly.
  ts: vector<text> = [];
  fs: vector<text> = [];
  cases: vector<text> = [];
  for lv in 1..4 {
    dir = "{source_dir()}/../corpus/a{lv}";
    // The names are collected before any file is read — listing and I/O kept apart, which
    // reads more plainly and was once required by a loft defect (LOFT-HANDOFF H6, fixed and
    // verified on 2026.7.2; loft now carries a guard test for it).
    names = list_dir(dir);
    picks: vector<text> = [];
    for ni in 0..len(names) {
      nm = names[ni] ?? "";
      if nm.ends_with(".t") { picks += [nm.replace(".t", "")]; }
    }
    nlv = len(picks);
    for pi in 0..nlv {
      base = picks[pi] ?? "";
      cases += [base];
      ts += [file("{dir}/{base}.t").content().trim()];
      fs += [file("{dir}/{base}.f").content().trim()];
    }
    println("   corpus/a{lv}: {nlv} committed entries");
  }
  n = len(cases);
  println("   {n} entries in total");
  if n <= 0 {
    println("  BROKEN: the corpus is empty — run src/corpusgen.loft and COMMIT the result");
    println("=== TRIP BROKEN ===");
    return;
  }

  // ── 1. EVERY COMMITTED T ROUND-TRIPS BYTE-FOR-BYTE ────────────────────────
  println("");
  println("1. write(read(T)) == T over the committed texts");
  nbad = 0;
  for ri in 0..n {
    tt = ts[ri] ?? "";
    rf = form_read(tt);
    if len(rf.fm_len) == 0 { nbad = nbad + 1; }
    else if form_write(rf, (cases[ri] ?? "a1-00").split('-')[0] ?? "a1") != tt { nbad = nbad + 1; }
  }
  println("   {n} entries, {nbad} mismatches");
  if nbad != 0 {
    println("  BROKEN: a committed text no longer round-trips — read/write changed under the"
            + " corpus. Look at the diff and DECIDE; do not regenerate."); ok = false;
  }

  // ── 2. draw(read(T)) STILL DIGESTS TO THE COMMITTED .f ────────────────────
  //
  // This is the regression anchor, and it is the half of the round trip that exists today.  If
  // `form_fill` or the digest ever changes, this fires against bytes written before the change.
  println("");
  println("2. digest(draw(read(T))) == the committed .f");
  ndig = 0;
  for di in 0..n {
    df = form_read(ts[di] ?? "");
    dc = hexset_chunk(Q0, R0, W, H);
    form_fill(df, 0, 0, dc);
    if field_exact_text(dc) != (fs[di] ?? "") { ndig = ndig + 1; }
  }
  println("   {n} entries, {ndig} digest mismatches");
  if ndig != 0 {
    println("  BROKEN: draw() no longer reproduces the committed field"); ok = false;
  }

  // ── 3. LAW F OVER THE CORPUS ──────────────────────────────────────────────
  //
  // No two DISTINCT entries may share a field.  The `.f` is the FAITHFUL digest — the cells
  // exactly as drawn — because law F is about `draw` being injective, not about how many shapes
  // the level holds.  The census's orientation-canonical digest answers the other question and
  // reported 17 false failures here before the two were separated.
  println("");
  println("3. law F — no two corpus entries share a field");
  nshare = 0;
  for ai in 0..n {
    for aj in 0..n {
      if ai < aj && (fs[ai] ?? "") == (fs[aj] ?? "") {
        nshare = nshare + 1;
        if nshare <= 3 {
          println("   {cases[ai] ?? \"\"} and {cases[aj] ?? \"\"} share a field");
        }
      }
    }
  }
  println("   {nshare} sharing pairs (must be 0)");
  if nshare != 0 {
    println("  BROKEN: two canonical texts draw the same field — law F fails on the corpus");
    ok = false;
  }
  // CONTROL: the comparison must be able to SEE a match, or 0 proves nothing.
  println("   CONTROL an entry against itself: {(fs[0] ?? \"a\") == (fs[0] ?? \"b\")}"
          + " (must be true)");
  if (fs[0] ?? "a") != (fs[0] ?? "b") {
    println("  BROKEN: control did not fire — the field comparison never matches"); ok = false;
  }

  // CONTROL: a NON-CANONICAL spelling must fail the byte diff.  This is the `snap` bypass in the
  // form it can take today — a model that was never canonicalised does not survive write(read(T)).
  raw = form_write(form_new(2, [1, 1, 1], [5, 5, 2]), "a1");
  canon = form_canon_text(form_new(2, [1, 1, 1], [5, 5, 2]), "a1");
  println("   CONTROL a non-canonical spelling differs from its canonical form:"
          + " {raw != canon} (must be true)");
  if raw == canon {
    println("  BROKEN: control did not fire — nothing was non-canonical to begin with"); ok = false;
  }

  // ── 4. THE FULL TRIP ──────────────────────────────────────────────────────
  //
  //     write(rebuild(draw(read(T))))  ==  T      byte-for-byte, for every committed entry
  //
  // Regime R1: the grammar is the prior, so this is an exact match against the enumerated set and
  // no tolerance appears anywhere in it (`P4`).
  println("");
  println("4. write(rebuild(draw(read(T)))) == T");
  if !ok {
    println("=== TRIP BROKEN ===");
    return;
  }
  if !REBUILD_LANDED {
    println("   PENDING — `rebuild` does not exist (S8).");
    println("");
    println("=== TRIP RED: rebuild absent ===");
    return;
  }
  // Build the candidate space ONCE — enumerating it is the expensive part, and doing it per
  // lookup would be quadratic over the corpus.
  cands = candidate_forms();
  // INDEXED RECOVERY: draw each candidate ONCE into a digest -> form map, then recover by probe.
  // The scan re-drew every candidate on every lookup — O(N) fills per field, O(N^2) over the
  // corpus. Law F is checked here, once over the whole space, instead of per lookup.
  idx = index_build(cands);
  println("   candidate space: {len(cands)} admitted forms");
  println("   index: {idx.ri_count} entries, {idx.ri_fills} fills to build,"
          + " {idx.ri_collisions} digest collisions");
  println("   the scan would have cost {len(cands) * n} fills for {n} lookups"
          + " — the index costs {idx.ri_fills}");
  if idx.ri_collisions != 0 {
    println("  FAIL: two candidates share a field digest — law F fails over the candidate"
            + " space, and an indexed lookup would silently return whichever won");
    ok = false;
  }
  if idx.ri_count != len(cands) {
    println("  FAIL: the index dropped candidates — {idx.ri_count} of {len(cands)}"); ok = false;
  }
  ntrip = 0;
  for ti in 0..n {
    tt = ts[ti] ?? "";
    m0 = form_read(tt);                                    // read(T)
    fc = hexset_chunk(Q0, R0, W, H);
    form_fill(m0, 0, 0, fc);                               // draw(...)
    got = rebuild_indexed_text(idx, cands, fc, (cases[ti] ?? "a1-00").split('-')[0] ?? "a1");
    if got != tt {
      ntrip = ntrip + 1;
      if ntrip <= 3 {
        println("   {cases[ti] ?? \"\"} DIFF:");
        println("     want: {tt.replace(\"\\n\", \" | \")}");
        println("     got:  {got.replace(\"\\n\", \" | \")}");
      }
    }
  }
  println("   {n} entries round-tripped byte-for-byte, {ntrip} diffs");
  if ntrip != 0 {
    println("  FAIL: the round trip does not reproduce the committed text"); ok = false;
  }
  // Every recovery must be R1 with rho = 0 and exactly ONE match — a second match would mean law
  // F failed at this level, which the census says it does not.
  nr1 = 0;
  for ri2 in 0..n {
    rc = hexset_chunk(Q0, R0, W, H);
    // Hoisted rather than inlined (LOFT-HANDOFF H4, fixed and verified on 2026.7.2). Kept
    // this way because it reads plainly, not because it is required.
    rm = form_read(ts[ri2] ?? "");
    form_fill(rm, 0, 0, rc);
    rr = rebuild_indexed(idx, cands, rc);
    if rr.rb_regime == REGIME_R1 && rr.rb_rho == 0 && rr.rb_matches == 1 { nr1 = nr1 + 1; }
  }
  println("   {nr1} of {n} recovered as R1, rho = 0, exactly one match");
  if nr1 != n {
    println("  FAIL: a corpus entry did not recover exactly — R1 must be exact"); ok = false;
  }

  // ── 5. THE CONTROL — A NON-GRAMMAR FOOTPRINT MUST LAND IN R2 ──────────────
  //
  // `STEPS.md` S8: hand `rebuild` a traced footprint no grammar form draws, and it must report
  // R2 with rho > 0 — NEVER a confident R1 answer. This is the one failure mode that would make
  // every downstream guarantee a lie, because an R1 answer carries "exact" with it.
  println("");
  println("5. CONTROL — a non-grammar footprint must land in R2, never silently in R1");
  blob = hexset_chunk(Q0, R0, W, H);
  hexset_set(blob, 0, 0, true);
  hexset_set(blob, 1, 0, true);
  hexset_set(blob, 2, 0, true);
  hexset_set(blob, 3, 0, true);
  hexset_set(blob, 0, 1, true);
  br2 = rebuild_indexed(idx, cands, blob);
  println("   a 5-cell hand-drawn blob -> regime R{br2.rb_regime}, rho {br2.rb_rho},"
          + " matches {br2.rb_matches}");
  if br2.rb_regime != REGIME_R2 {
    println("  FAIL: a non-grammar footprint was returned as an EXACT R1 answer"); ok = false;
  }
  if br2.rb_rho <= 0 {
    println("  FAIL: R2 reported no residual — rho must be > 0 and surfaced"); ok = false;
  }
  if rebuild_indexed_text(idx, cands, blob, "a1") != "" {
    println("  FAIL: an R2 guess was spelled as if it were an authored stencil"); ok = false;
  }
  // and the control must not be vacuous: a REAL corpus field still comes back R1
  chk = hexset_chunk(Q0, R0, W, H);
  cm = form_read(ts[0] ?? "");
  form_fill(cm, 0, 0, chk);
  cr2 = rebuild_indexed(idx, cands, chk);
  println("   CONTROL a real corpus field -> regime R{cr2.rb_regime}, rho {cr2.rb_rho}"
          + " (must be R1, 0)");
  if cr2.rb_regime != REGIME_R1 {
    println("  FAIL: control did not fire — rebuild calls everything R2"); ok = false;
  }

  // ── 6. CONTROL — THE INDEX MUST AGREE WITH THE SCAN IT REPLACES ──────────
  //
  // A faster recovery that quietly answers differently is worse than a slow one. Every corpus
  // entry is recovered BOTH ways and the two must give the same form.
  println("");
  println("6. CONTROL — indexed recovery agrees with the scan it replaces");
  ndis = 0;
  for xi in 0..n {
    xc = hexset_chunk(Q0, R0, W, H);
    xm = form_read(ts[xi] ?? "");
    form_fill(xm, 0, 0, xc);
    a = rebuild_indexed(idx, cands, xc);
    b = rebuild_with(cands, xc);
    if a.rb_regime != b.rb_regime { ndis = ndis + 1; }
    else if a.rb_regime == REGIME_R1
            && form_write(a.rb_form, "z") != form_write(b.rb_form, "z") { ndis = ndis + 1; }
  }
  println("   {n} entries recovered both ways, {ndis} disagreements");
  if ndis != 0 {
    println("  FAIL: the index and the scan disagree — the fast path is not the same answer");
    ok = false;
  }
  // and the R2 path must agree too, since that is where the index falls back to the scan
  bi = rebuild_indexed(idx, cands, blob);
  bs = rebuild_with(cands, blob);
  println("   CONTROL the blob both ways: R{bi.rb_regime}/rho {bi.rb_rho} vs"
          + " R{bs.rb_regime}/rho {bs.rb_rho} (must match)");
  if bi.rb_regime != bs.rb_regime || bi.rb_rho != bs.rb_rho {
    println("  FAIL: the index and the scan disagree on R2 content"); ok = false;
  }

  // ── 7. CONSTRUCTIVE RECOVERY — no enumeration, and it reaches further ─────
  //
  // Indexed recovery is fast but is BUILT BY the enumeration, so it can only ever recover what was
  // enumerated. Constructive recovery reads (h0, lens, turns) off the field's own geometry — hull
  // the filled cells, the hull vertices ARE the turtle's corners — in O(cells), independent of how
  // large the admissible space is. It proposes, then VERIFIES by re-drawing, so `rho = 0` stays a
  // measured fact.
  println("");
  println("7. CONSTRUCTIVE RECOVERY — reads the form off the field, enumerating nothing");
  ncon = 0;
  for yi in 0..n {
    yc = hexset_chunk(Q0, R0, W, H);
    ym = form_read(ts[yi] ?? "");
    form_fill(ym, 0, 0, yc);
    yname = (cases[yi] ?? "a1-00").split('-')[0] ?? "a1";
    if rebuild_construct_text(yc, yname) != (ts[yi] ?? "") { ncon = ncon + 1; }
  }
  println("   {n} committed entries recovered constructively, {ncon} diffs");
  if ncon != 0 {
    println("  FAIL: constructive recovery does not reproduce the committed text"); ok = false;
  }

  // THE POINT OF THE EXERCISE: a form OUTSIDE the enumerated space. Today's 4-sided house
  // [4,5,4,5] needs maxlen 5 — ~1.2M proposals to enumerate (`X43`) — so it is deliberately not a
  // candidate. Indexed recovery must therefore MISS it, and constructive recovery must not.
  house = form_new(0, [4, 5, 4, 5], [2, 4, 2, 4]);
  hcells = hexset_chunk(Q0, R0, W, H);
  nhc = form_fill(house, 0, 0, hcells);
  hidx = rebuild_indexed(idx, cands, hcells);
  hcon = rebuild_construct(hcells);
  println("   the 4-sided house [4,5,4,5], {nhc} cells:");
  println("     indexed      -> regime R{hidx.rb_regime}, rho {hidx.rb_rho}   (outside the"
          + " enumerated space, so it CANNOT be found this way)");
  println("     constructive -> regime R{hcon.rb_regime}, rho {hcon.rb_rho}");
  if hidx.rb_regime != REGIME_R2 {
    println("  FAIL: the house was found by enumeration — then it is not outside the space and"
            + " this comparison proves nothing"); ok = false;
  }
  if hcon.rb_regime != REGIME_R1 || hcon.rb_rho != 0 {
    println("  FAIL: constructive recovery did not recover the house exactly"); ok = false;
  }
  if rebuild_construct_text(hcells, "house") != form_canon_text(house, "house") {
    println("  FAIL: the recovered house is not the house that was drawn"); ok = false;
  }
  println("     => constructive recovery reaches STRICTLY FURTHER than the enumeration");

  // CONTROL: it must still refuse non-grammar content, or "reaches further" would just mean
  // "answers anything".
  bcon = rebuild_construct(blob);
  println("   CONTROL the hand-drawn blob -> regime R{bcon.rb_regime}, rho {bcon.rb_rho},"
          + " text '{rebuild_construct_text(blob, \"b\")}'");
  if bcon.rb_regime != REGIME_R2 || bcon.rb_rho <= 0 {
    println("  FAIL: constructive recovery returned an R1 answer for a hand-drawn blob"); ok = false;
  }
  if rebuild_construct_text(blob, "b") != "" {
    println("  FAIL: an R2 guess was spelled as an authored stencil"); ok = false;
  }

  println("");
  if ok { println("=== TRIP OK ==="); }
  else { println("=== TRIP BROKEN ==="); }
}
