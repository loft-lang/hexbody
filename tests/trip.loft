// trip — THE ROUND-TRIP GATE (`rt_trip`), STEP S7.  WRITTEN BEFORE `rebuild` EXISTS.
//
//     for every entry:   write(rebuild(draw(read(T))))  ==  T     byte-for-byte   (P3/P4)
//     for every pair:    f(a) != f(b)                             law F
//
// It is RED on purpose until S8 lands `rebuild`, and `tools/run_tests.sh` ASSERTS that redness —
// so the gate runs on every `make test` (it cannot rot), and if it ever goes green by accident
// the runner FAILS and demands the row be promoted.  Red for the stated reason, never red because
// it crashed.
//
// THE CORPUS IS READ, NEVER REGENERATED (`DESIGN.md` §8.0).  `src/corpusgen.loft` wrote these
// bytes once and they are committed; a gate that regenerates its own baseline compares new output
// against new output and passes unconditionally.  Everything below reads the committed files.
//
//   1  every committed T round-trips through read/write BYTE-FOR-BYTE
//   2  draw(read(T)) still digests to the committed .f — the regression anchor
//   3  law F over the corpus: no two entries share a field
//   4  the full trip — needs `rebuild`, so RED until S8
use hex_field;
use hexform;
use formcensus;
use formtext;
use formfit;

const W = 61;
const H = 61;
const Q0 = -30;
const R0 = -30;

fn main() {
  ok = true;
  println("=== rt_trip — the round trip, against the committed corpus ===");

  dir = "{source_dir()}/../corpus/a1";
  names = list_dir(dir);
  ts: vector<text> = [];
  fs: vector<text> = [];
  cases: vector<text> = [];
  for ni in 0..len(names) {
    nm = names[ni] ?? "";
    if nm.ends_with(".t") {
      base = nm.replace(".t", "");
      cases += [base];
      ts += [file("{dir}/{base}.t").content().trim()];
      fs += [file("{dir}/{base}.f").content().trim()];
    }
  }
  n = len(cases);
  println("   {n} committed entries in corpus/a1");
  if n <= 0 {
    println("  BROKEN: the corpus is empty — run src/corpusgen.loft and COMMIT the result");
    println("=== TRIP BROKEN ===");
    return;
  }

  // ── 1. EVERY COMMITTED T ROUND-TRIPS BYTE-FOR-BYTE ────────────────────────
  println("");
  println("1. write(read(T)) == T over the committed texts");
  nbad = 0;
  for ri in 0..n {
    tt = ts[ri] ?? "";
    rf = form_read(tt);
    if len(rf.fm_len) == 0 { nbad = nbad + 1; }
    else if form_write(rf, "a1") != tt { nbad = nbad + 1; }
  }
  println("   {n} entries, {nbad} mismatches");
  if nbad != 0 {
    println("  BROKEN: a committed text no longer round-trips — read/write changed under the"
            + " corpus. Look at the diff and DECIDE; do not regenerate."); ok = false;
  }

  // ── 2. draw(read(T)) STILL DIGESTS TO THE COMMITTED .f ────────────────────
  //
  // This is the regression anchor, and it is the half of the round trip that exists today.  If
  // `form_fill` or the digest ever changes, this fires against bytes written before the change.
  println("");
  println("2. digest(draw(read(T))) == the committed .f");
  ndig = 0;
  for di in 0..n {
    df = form_read(ts[di] ?? "");
    dc = hexset_chunk(Q0, R0, W, H);
    form_fill(df, 0, 0, dc);
    if field_exact_text(dc) != (fs[di] ?? "") { ndig = ndig + 1; }
  }
  println("   {n} entries, {ndig} digest mismatches");
  if ndig != 0 {
    println("  BROKEN: draw() no longer reproduces the committed field"); ok = false;
  }

  // ── 3. LAW F OVER THE CORPUS ──────────────────────────────────────────────
  //
  // No two DISTINCT entries may share a field.  The `.f` is the FAITHFUL digest — the cells
  // exactly as drawn — because law F is about `draw` being injective, not about how many shapes
  // the level holds.  The census's orientation-canonical digest answers the other question and
  // reported 17 false failures here before the two were separated.
  println("");
  println("3. law F — no two corpus entries share a field");
  nshare = 0;
  for ai in 0..n {
    for aj in 0..n {
      if ai < aj && (fs[ai] ?? "") == (fs[aj] ?? "") {
        nshare = nshare + 1;
        if nshare <= 3 {
          println("   {cases[ai] ?? \"\"} and {cases[aj] ?? \"\"} share a field");
        }
      }
    }
  }
  println("   {nshare} sharing pairs (must be 0)");
  if nshare != 0 {
    println("  BROKEN: two canonical texts draw the same field — law F fails on the corpus");
    ok = false;
  }
  // CONTROL: the comparison must be able to SEE a match, or 0 proves nothing.
  println("   CONTROL an entry against itself: {(fs[0] ?? \"a\") == (fs[0] ?? \"b\")}"
          + " (must be true)");
  if (fs[0] ?? "a") != (fs[0] ?? "b") {
    println("  BROKEN: control did not fire — the field comparison never matches"); ok = false;
  }

  // CONTROL: a NON-CANONICAL spelling must fail the byte diff.  This is the `snap` bypass in the
  // form it can take today — a model that was never canonicalised does not survive write(read(T)).
  raw = form_write(form_new(2, [1, 1, 1], [5, 5, 2]), "a1");
  canon = form_canon_text(form_new(2, [1, 1, 1], [5, 5, 2]), "a1");
  println("   CONTROL a non-canonical spelling differs from its canonical form:"
          + " {raw != canon} (must be true)");
  if raw == canon {
    println("  BROKEN: control did not fire — nothing was non-canonical to begin with"); ok = false;
  }

  // ── 4. THE FULL TRIP ──────────────────────────────────────────────────────
  //
  //     write(rebuild(draw(read(T))))  ==  T      byte-for-byte, for every committed entry
  //
  // Regime R1: the grammar is the prior, so this is an exact match against the enumerated set and
  // no tolerance appears anywhere in it (`P4`).
  println("");
  println("4. write(rebuild(draw(read(T)))) == T");
  if !ok {
    println("=== TRIP BROKEN ===");
    return;
  }
  if !REBUILD_LANDED {
    println("   PENDING — `rebuild` does not exist (S8).");
    println("");
    println("=== TRIP RED: rebuild absent ===");
    return;
  }
  ntrip = 0;
  for ti in 0..n {
    tt = ts[ti] ?? "";
    m0 = form_read(tt);                                    // read(T)
    fc = hexset_chunk(Q0, R0, W, H);
    form_fill(m0, 0, 0, fc);                               // draw(...)
    got = rebuild_text(fc, "a1");                          // write(rebuild(...))
    if got != tt {
      ntrip = ntrip + 1;
      if ntrip <= 3 {
        println("   {cases[ti] ?? \"\"} DIFF:");
        println("     want: {tt.replace(\"\\n\", \" | \")}");
        println("     got:  {got.replace(\"\\n\", \" | \")}");
      }
    }
  }
  println("   {n} entries round-tripped byte-for-byte, {ntrip} diffs");
  if ntrip != 0 {
    println("  FAIL: the round trip does not reproduce the committed text"); ok = false;
  }
  // Every recovery must be R1 with rho = 0 and exactly ONE match — a second match would mean law
  // F failed at this level, which the census says it does not.
  nr1 = 0;
  for ri2 in 0..n {
    rc = hexset_chunk(Q0, R0, W, H);
    // HOISTED, never inline: a struct built in an argument list beside a store-allocated value
    // is corrupted from the second loop iteration (crawler LOFT-HANDOFF H4). Inlining this read
    // 9 of 10 instead of 10 of 10, while the hoisted loop above was byte-perfect.
    rm = form_read(ts[ri2] ?? "");
    form_fill(rm, 0, 0, rc);
    rr = rebuild(rc);
    if rr.rb_regime == REGIME_R1 && rr.rb_rho == 0 && rr.rb_matches == 1 { nr1 = nr1 + 1; }
  }
  println("   {nr1} of {n} recovered as R1, rho = 0, exactly one match");
  if nr1 != n {
    println("  FAIL: a corpus entry did not recover exactly — R1 must be exact"); ok = false;
  }

  // ── 5. THE CONTROL — A NON-GRAMMAR FOOTPRINT MUST LAND IN R2 ──────────────
  //
  // `STEPS.md` S8: hand `rebuild` a traced footprint no grammar form draws, and it must report
  // R2 with rho > 0 — NEVER a confident R1 answer. This is the one failure mode that would make
  // every downstream guarantee a lie, because an R1 answer carries "exact" with it.
  println("");
  println("5. CONTROL — a non-grammar footprint must land in R2, never silently in R1");
  blob = hexset_chunk(Q0, R0, W, H);
  hexset_set(blob, 0, 0, true);
  hexset_set(blob, 1, 0, true);
  hexset_set(blob, 2, 0, true);
  hexset_set(blob, 3, 0, true);
  hexset_set(blob, 0, 1, true);
  br2 = rebuild(blob);
  println("   a 5-cell hand-drawn blob -> regime R{br2.rb_regime}, rho {br2.rb_rho},"
          + " matches {br2.rb_matches}");
  if br2.rb_regime != REGIME_R2 {
    println("  FAIL: a non-grammar footprint was returned as an EXACT R1 answer"); ok = false;
  }
  if br2.rb_rho <= 0 {
    println("  FAIL: R2 reported no residual — rho must be > 0 and surfaced"); ok = false;
  }
  if rebuild_text(blob, "a1") != "" {
    println("  FAIL: an R2 guess was spelled as if it were an authored stencil"); ok = false;
  }
  // and the control must not be vacuous: a REAL corpus field still comes back R1
  chk = hexset_chunk(Q0, R0, W, H);
  cm = form_read(ts[0] ?? "");
  form_fill(cm, 0, 0, chk);
  cr2 = rebuild(chk);
  println("   CONTROL a real corpus field -> regime R{cr2.rb_regime}, rho {cr2.rb_rho}"
          + " (must be R1, 0)");
  if cr2.rb_regime != REGIME_R1 {
    println("  FAIL: control did not fire — rebuild calls everything R2"); ok = false;
  }

  println("");
  if ok { println("=== TRIP OK ==="); }
  else { println("=== TRIP BROKEN ==="); }
}
