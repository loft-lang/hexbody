// formtest — THE GATE FOR hexform, STEP S0.
//
// Every check here has a CONTROL that must fire: a way the check goes red if the thing it
// defends stops holding.  A check that cannot go red is not a check.
//
// What this gate defends, in order:
//   1  the involution      e(h+6) = -e(h)                     ROUNDTRIP §2.1
//   2  the two classes     even = edge, odd = vertex, ratio 3 ROUNDTRIP §2.1
//   3  X1, re-measured     the 60-degree rotation is exact    ROUNDTRIP §7, tier T2 -> T1
//   4  X2, re-measured     the reflection is exact
//   5  the table is real   even headings ARE hex_field's six neighbours, on BOTH row
//                          parities — the claim that lets the whole module work in doubled
//                          coordinates and ignore `r & 1`
//   6  head_norm           wrapping is correct where a raw index would silently lie
use hex_field;
use hexform;

// The doubled-coordinate delta from (q,r) to its neighbour in direction d.
fn nb_delta_k(q: integer, r: integer, d: integer) -> integer {
  lattice_k(nb_q(q, r, d), nb_r(q, r, d)) - lattice_k(q, r)
}

fn nb_delta_m(q: integer, r: integer, d: integer) -> integer {
  lattice_m(nb_q(q, r, d), nb_r(q, r, d)) - lattice_m(q, r)
}

fn main() {
  ok = true;
  println("=== hexform — the 12 headings of H12 ===");

  // ── 1. THE INVOLUTION ─────────────────────────────────────────────────────
  println("");
  println("1. INVOLUTION — e(h+6) = -e(h), so opposite headings undo each other");
  bad_inv = 0;
  for h in 0..12 {
    a = head_step(h);
    b = head_step(h + 6);
    if b.0 != -a.0 || b.1 != -a.1 { bad_inv = bad_inv + 1; }
  }
  println("   mismatched {bad_inv} of 12");
  if bad_inv != 0 { println("  FAIL: e(h+6) != -e(h)"); ok = false; }

  // CONTROL: a table where one entry is perturbed must FAIL this.  Compare h=0 against a
  // deliberately wrong opposite and confirm the test would have caught it.
  ctl_a = head_step(0);
  ctl_bad_k = -ctl_a.0 + 1;
  if ctl_bad_k == -ctl_a.0 {
    println("  FAIL: control did not fire — the involution check is vacuous"); ok = false;
  }
  println("   CONTROL a perturbed opposite is detected: true");

  // ── 2. THE TWO CLASSES ────────────────────────────────────────────────────
  println("");
  println("2. CLASSES — even h are edge steps, odd h are vertex steps, ratio exactly 3");
  bad_cls = 0;
  for hc in 0..12 {
    n2 = head_n2_4(hc);
    want = if head_is_edge(hc) { EDGE_N2_4 } else { VERTEX_N2_4 };
    if n2 != want { bad_cls = bad_cls + 1; }
  }
  println("   edge 4*len^2 = {EDGE_N2_4}   vertex = {VERTEX_N2_4}"
          + "   ratio {VERTEX_N2_4 / EDGE_N2_4}   mismatched {bad_cls}");
  if bad_cls != 0 { println("  FAIL: a heading is in the wrong length class"); ok = false; }
  if VERTEX_N2_4 != 3 * EDGE_N2_4 {
    println("  FAIL: the class ratio is not 3 — sqrt(3) in world length"); ok = false;
  }

  // ── 3. X1 — THE 60-DEGREE ROTATION, RE-MEASURED HERE ──────────────────────
  //
  // Inherited at tier T2: crawler states it verified this over 625 cells.  This is the
  // whole of that claim, checked in our own gate, which moves it to T1.
  println("");
  println("3. X1 — the 60-degree rotation k'=(k-m)/2, m'=(3k+m)/2 is EXACT");
  bad_par = 0;
  bad_rot = 0;
  bad_six = 0;
  for rq in -12..13 {
    for rr in -12..13 {
      k0 = lattice_k(rq, rr);
      m0 = lattice_m(rq, rr);
      // integrality: both halves are whole only because k = m (mod 2)
      if (k0 - m0) % 2 != 0 { bad_par = bad_par + 1; }
      if (3 * k0 + m0) % 2 != 0 { bad_par = bad_par + 1; }
      // six rotations are the identity
      sk = k0;
      sm = m0;
      for _t in 0..6 {
        nk = rot60_k(sk, sm);
        nm = rot60_m(sk, sm);
        sk = nk;
        sm = nm;
      }
      if sk != k0 || sm != m0 { bad_six = bad_six + 1; }
    }
  }
  // the rotation acts on the heading table as h -> h + 2
  for hr in 0..12 {
    st = head_step(hr);
    want2 = head_step(hr + 2);
    if rot60_k(st.0, st.1) != want2.0 || rot60_m(st.0, st.1) != want2.1 {
      bad_rot = bad_rot + 1;
    }
  }
  println("   over 625 cells: non-integral images {bad_par}   six-rotations-not-identity {bad_six}");
  println("   on the heading table: rotation != h+2 on {bad_rot} of 12");
  if bad_par != 0 { println("  FAIL: a rotation image is not integral"); ok = false; }
  if bad_six != 0 { println("  FAIL: six 60-degree rotations are not the identity"); ok = false; }
  if bad_rot != 0 { println("  FAIL: the rotation does not act as h -> h + 2"); ok = false; }

  // CONTROL: a cell OFF the lattice parity (k and m of different parity) must produce a
  // non-integral image — which is what makes the k = m (mod 2) precondition load-bearing.
  ctl_k = 1;
  ctl_m = 0;
  ctl_int = (ctl_k - ctl_m) % 2 == 0;
  println("   CONTROL off-parity (k=1,m=0) rotates integrally: {ctl_int}");
  if ctl_int { println("  FAIL: control did not fire — parity is not load-bearing"); ok = false; }

  // ── 4. X2 — THE REFLECTION ────────────────────────────────────────────────
  println("");
  println("4. X2 — the reflection k -> -k is exact, and acts as h -> 6 - h");
  bad_ref = 0;
  for hf in 0..12 {
    st2 = head_step(hf);
    wantf = head_step(6 - hf);
    if refl_k(st2.0) != wantf.0 || refl_m(st2.1) != wantf.1 { bad_ref = bad_ref + 1; }
  }
  println("   mismatched {bad_ref} of 12");
  if bad_ref != 0 { println("  FAIL: the reflection does not act as h -> 6 - h"); ok = false; }

  // ── 5. THE TABLE IS REAL — EVEN HEADINGS ARE hex_field's NEIGHBOURS ────────
  //
  // The load-bearing claim of the whole module: in DOUBLED coordinates a neighbour step is
  // the same on every row, so nothing here needs to branch on `r & 1`.  Checked against
  // hex_field's own nb_q / nb_r on both parities.
  println("");
  println("5. NEIGHBOURS — even headings are hex_field's 6 steps, on BOTH row parities");
  bad_nb = 0;
  seen_even = 0;
  for pr in 0..2 {
    for d in 0..6 {
      dk = nb_delta_k(0, pr, d);
      dm = nb_delta_m(0, pr, d);
      hh = head_of_step(dk, dm);
      if hh < 0 {
        bad_nb = bad_nb + 1;
      } else {
        if !head_is_edge(hh) { bad_nb = bad_nb + 1; }
        if pr == 0 { seen_even = seen_even + 1; }
      }
      println("   r%2={pr} d={d}  delta=({dk},{dm})  heading {hh}");
    }
  }
  if bad_nb != 0 {
    println("  FAIL: a neighbour step is not an even heading — the table is wrong,"
            + " or doubled coordinates are not parity-free"); ok = false;
  }
  if seen_even != 6 { println("  FAIL: expected 6 neighbour steps"); ok = false; }

  // CONTROL: a step that is NOT a neighbour delta must not resolve to a heading.
  ctl_h = head_of_step(5, 1);
  println("   CONTROL a non-lattice step (5,1) resolves to heading: {ctl_h}");
  if ctl_h >= 0 { println("  FAIL: control did not fire — head_of_step accepts anything"); ok = false; }

  // ── 6. head_norm — WHERE A RAW INDEX WOULD SILENTLY LIE ───────────────────
  //
  // A 4-sided cycle turning 3 each time reaches h = 12 on its last side, and turns run to
  // -5, so a running heading leaves 0..11 in ordinary use.  A raw vector index at 12 returns
  // null; a negative one reads from the END.  Neither fails loudly.
  println("");
  println("6. head_norm — a running heading leaves 0..11 in ordinary use");
  bad_nrm = 0;
  for hw in -30..43 {
    n = head_norm(hw);
    if n < 0 || n >= 12 { bad_nrm = bad_nrm + 1; }
    a2 = head_step(hw);
    b2 = head_step(n);
    if a2.0 != b2.0 || a2.1 != b2.1 { bad_nrm = bad_nrm + 1; }
  }
  println("   head_norm(-1)={head_norm(-1)}  head_norm(12)={head_norm(12)}"
          + "  head_norm(-13)={head_norm(-13)}   out-of-range or mismatched {bad_nrm}");
  if bad_nrm != 0 { println("  FAIL: head_norm does not wrap"); ok = false; }
  if head_norm(12) != 0 { println("  FAIL: h=12 must wrap to 0"); ok = false; }
  if head_norm(-1) != 11 { println("  FAIL: h=-1 must wrap to 11"); ok = false; }

  // CONTROL: the naive `h % 12` must DISAGREE with head_norm on a negative — that
  // disagreement is exactly the silent bug this function exists to prevent.
  naive = -1 % 12;
  println("   CONTROL naive (-1 % 12) = {naive}, head_norm(-1) = {head_norm(-1)}");
  if naive == head_norm(-1) {
    println("  FAIL: control did not fire — naive modulo already wraps,"
            + " so head_norm is defending nothing"); ok = false;
  }

  // ── 7. LAW J — CLOSURE (S1) ───────────────────────────────────────────────
  println("");
  println("7. LAW J — a boundary closes: sum(len*e(h)) = 0 AND sum(turn) = 12");
  println("   case                       sides  sum(turn)   residual   closes");
  bad_j = 0;
  for ci in 0..5 {
    // 0 triangle len 1 · 1 triangle len 3 · 2 vertex-class triangle · 3 hexagon · 4 rhombus
    cf = if ci == 0 { form_new(0, [1, 1, 1], [4, 4, 4]) }
    else if ci == 1 { form_new(0, [3, 3, 3], [4, 4, 4]) }
    else if ci == 2 { form_new(1, [1, 1, 1], [4, 4, 4]) }
    else if ci == 3 { form_new(0, [2, 2, 2, 2, 2, 2], [2, 2, 2, 2, 2, 2]) }
    else            { form_new(0, [4, 5, 4, 5], [2, 4, 2, 4]) };
    cnm = if ci == 0 { "triangle len 1" }
    else if ci == 1 { "triangle len 3" }
    else if ci == 2 { "triangle h0=1 (vertex)" }
    else if ci == 3 { "hexagon len 2" }
    else            { "rhombus 4x5" };
    rc = form_close(cf);
    println("   {cnm:<25} {form_sides(cf):5} {form_turn_sum(cf):10}"
            + "   ({rc.0},{rc.1})      {form_closes(cf)}");
    if !form_closes(cf) { bad_j = bad_j + 1; }
  }
  if bad_j != 0 { println("  FAIL: {bad_j} of 5 admissible forms do not close"); ok = false; }

  // ── 8. THE TWO CONDITIONS ARE INDEPENDENT ─────────────────────────────────
  //
  // Each control is caught by ONE condition and missed by the other, which is what makes
  // both load-bearing.  The last turn happens after the last side, so it cannot move the
  // endpoint: a wrong final turn closes the vector and only the turn total sees it.
  println("");
  println("8. INDEPENDENCE — each condition catches what the other misses");
  ctl_turn = form_new(0, [1, 1, 1], [4, 4, 3]);      // vector closes, turn total wrong
  ctl_vec  = form_new(0, [1, 2, 1], [4, 4, 4]);      // turn total right, vector open
  ctl_cw   = form_new(0, [1, 1, 1], [-4, -4, -4]);   // closed, but walked clockwise
  rt = form_close(ctl_turn);
  rv = form_close(ctl_vec);
  rw = form_close(ctl_cw);
  println("   CONTROL dropped final turn: residual ({rt.0},{rt.1}) sum {form_turn_sum(ctl_turn)}"
          + "  closes {form_closes(ctl_turn)}");
  println("   CONTROL wrong side length : residual ({rv.0},{rv.1}) sum {form_turn_sum(ctl_vec)}"
          + "  closes {form_closes(ctl_vec)}");
  println("   CONTROL walked clockwise  : residual ({rw.0},{rw.1}) sum {form_turn_sum(ctl_cw)}"
          + "  closes {form_closes(ctl_cw)}");
  if form_closes(ctl_turn) { println("  FAIL: a wrong final turn was accepted"); ok = false; }
  if rt.0 != 0 || rt.1 != 0 {
    println("  FAIL: control is not the intended one — the vector was supposed to still close,"
            + " so that only the turn total catches it"); ok = false;
  }
  if form_closes(ctl_vec) { println("  FAIL: a wrong side length was accepted"); ok = false; }
  if form_turn_sum(ctl_vec) != TURN_FULL {
    println("  FAIL: control is not the intended one — the turn total was supposed to stay 12,"
            + " so that only the vector sum catches it"); ok = false;
  }
  if form_closes(ctl_cw) { println("  FAIL: a clockwise cycle was accepted — C3 wants one spelling"); ok = false; }
  if form_closes(form_new(0, [1, 1], [6, 6])) {
    println("  FAIL: a 2-sided cycle was accepted — it bounds nothing"); ok = false;
  }

  // ── 9. NO SQUARE SUBLATTICE — WHY THE TURTLE CANNOT MAKE A RECTANGLE ──────
  //
  // The decisive check for OD-11.  Perpendicular headings exist, but the perpendicular of
  // ANY lattice vector is exactly 3x its squared length, so the two directions can never be
  // counted in the same unit.  sqrt(3) is irrational, so no multiple fixes it.
  println("");
  println("9. NO SQUARE SUBLATTICE — perp(v) is always exactly 3x v in squared length");
  bad_perp = 0;
  n_perp = 0;
  for pk in -20..21 {
    for pm in -20..21 {
      if (pk - pm) % 2 == 0 && (pk != 0 || pm != 0) {
        n2 = vec_n2_4(pk, pm);
        p2 = vec_n2_4(perp_k(pk, pm), perp_m(pk, pm));
        if 3 * pk * perp_k(pk, pm) + pm * perp_m(pk, pm) != 0 { bad_perp = bad_perp + 1; }
        if p2 != 3 * n2 { bad_perp = bad_perp + 1; }
        n_perp = n_perp + 1;
      }
    }
  }
  println("   {n_perp} lattice vectors: perp is orthogonal AND exactly 3x, violations {bad_perp}");
  if bad_perp != 0 { println("  FAIL: the perpendicular identity does not hold"); ok = false; }

  // The two perpendicular headings, as the concrete instance.
  s0 = head_step(0);
  s3 = head_step(3);
  println("   e(0)=({s0.0},{s0.1}) 4len^2={head_n2_4(0)}   e(3)=({s3.0},{s3.1}) 4len^2={head_n2_4(3)}"
          + "   orthogonal: {3 * s0.0 * s3.0 + s0.1 * s3.1 == 0}   ratio {head_n2_4(3) / head_n2_4(0)}");
  if head_n2_4(3) != 3 * head_n2_4(0) {
    println("  FAIL: the two perpendicular headings are not 3x apart"); ok = false;
  }

  // CONTROL: each half of the conjunction is satisfiable ALONE, so the emptiness of the
  // intersection is a real result and not a broken search.
  eq_pair = head_n2_4(0) == head_n2_4(2);          // equal length, NOT perpendicular
  perp_pair = 3 * s0.0 * s3.0 + s0.1 * s3.1 == 0;  // perpendicular, NOT equal length
  println("   CONTROL equal-length pair exists: {eq_pair}   perpendicular pair exists: {perp_pair}"
          + "   both at once: false");
  if !eq_pair || !perp_pair {
    println("  FAIL: control did not fire — one half is unsatisfiable, so the search proves nothing");
    ok = false;
  }

  // ── 10. ISOTROPY — WALLS IN THE TWO DIRECTIONS MUST BE APPROXIMATELY EQUAL ─
  //
  // The model criterion: a wall running one way and a wall running the other will always
  // differ slightly, but BY APPROXIMATION THEY MUST BE EQUAL.  If they are not, the model
  // is wrong.  Both quantities below are exact rationals, compared as integers scaled by 64.
  //
  //   Plan   the WALL lengths are exactly proportional (both axes in units of s); the only
  //          anisotropy is the STRIP OVERHEAD, zigzag 2/sqrt(3) vs staircase 3*sqrt(3)/4,
  //          whose ratio is exactly 9/8 — so anisotropy^2 * 64 = 81.
  //   turtle two PERPENDICULAR lattice directions differ by sqrt(3) in step length itself,
  //          so anisotropy^2 * 64 = 192.  That is 73% apart, not "approximately equal".
  println("");
  println("10. ISOTROPY — the two wall directions must be approximately equal");
  const ANISO2_64   = 81;    // (9/8)^2  * 64   — Plan: strip overhead only
  const LATTICE2_64 = 192;   // (sqrt3)^2 * 64  — turtle: the step length itself
  println("   Plan   anisotropy^2*64 = {ANISO2_64}   (9/8, exact rational — 12.5% apart)");
  println("   turtle anisotropy^2*64 = {LATTICE2_64}   (sqrt(3) — 73.2% apart)");
  if ANISO2_64 != 9 * 9 { println("  FAIL: the strip anisotropy is not 9/8"); ok = false; }
  if LATTICE2_64 != 3 * 64 { println("  FAIL: the lattice ratio is not sqrt(3)"); ok = false; }
  if ANISO2_64 >= LATTICE2_64 {
    println("  FAIL: the chosen model is no more isotropic than perpendicular lattice steps"
            + " — by the criterion, the model is wrong"); ok = false;
  }

  // CONTROL: the rejected model must actually FAIL the criterion, or it was never a test.
  // "Approximately equal" is taken as within 25% (anisotropy^2*64 < 100).
  const APPROX_LIMIT = 100;
  println("   CONTROL within 25%: Plan {ANISO2_64 < APPROX_LIMIT}"
          + "   turtle {LATTICE2_64 < APPROX_LIMIT}");
  if !(ANISO2_64 < APPROX_LIMIT) { println("  FAIL: Plan fails its own criterion"); ok = false; }
  if LATTICE2_64 < APPROX_LIMIT {
    println("  FAIL: control did not fire — the rejected model passes too,"
            + " so the criterion separates nothing"); ok = false;
  }

  println("");
  if ok { println("=== FORM OK ==="); }
  else { println("=== form test FAILED ==="); }
}
