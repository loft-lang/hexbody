// census — THE GATE FOR formcensus.  Every check has a control that must fire.
//
// `rt_census_a`, grown by level.  Each level is finite, so law **F** is DECIDED there, not
// sampled.  Level `n` is every 3-sided form whose longest side is `n`, over all 12 starting
// headings and every turn triple summing to 12, filtered by law J.
//
//   1  the enumeration is exhaustive and law J is the admission filter
//   2  THE FRONTIER, per level: forms, distinct shapes, and whether `draw` stays INJECTIVE
//   3  what the shape-collisions are made of — rotations, and (from level 2) MIRRORS
//   4  controls: a summary digest collides at once; a turn-blind key merges distinct forms
//
// WHAT CHANGED AT A2, AND WHY THE OLD CHECK WAS LEVEL-1-SPECIFIC.  The first version asserted
// that every shape-collision is a cyclic RE-SPELLING of one turn sequence.  That holds at level 1
// only because equal sides make every admitted form ACHIRAL.  From level 2 unequal sides produce
// chiral forms, and a form and its mirror share a shape digest with REVERSED turns — so the old
// test reported 36 "unexplained" collisions that are simply the flip doing its job.
//
// It was also the wrong instrument: shape-collisions are grouped BY `field_digest`, which
// quotients by orientation, so "every collision is an orientation-image" is a tautology.  The
// non-vacuous law F question is whether `draw` is INJECTIVE, and that is `field_norm` — section 2.
use hex_field;
use hexform;
use formcensus;
use formtext;
use formfit;

const W = 61;
const H = 61;
const Q0 = -30;
const R0 = -30;

fn main() {
  ok = true;
  println("=== formcensus — the level-1 census, and law F decided at that level ===");

  // ── 1. THE ADMISSION FILTER ───────────────────────────────────────────────
  println("");
  println("1. ENUMERATION — law J is the admission filter, not a formality");
  nprop = 0;
  nadm = 0;
  for eh in 0..12 {
    for ea in 1..12 {
      for eb in 1..12 {
        ec = 12 - ea - eb;
        if ec >= 1 && ec <= 11 {
          nprop = nprop + 1;
          ef = form_new(eh, [1, 1, 1], [ea, eb, ec]);
          if form_closes(ef) { nadm = nadm + 1; }
        }
      }
    }
  }
  println("   at level 1: proposed {nprop}, law J admitted {nadm}");
  if nadm <= 0 { println("  FAIL: nothing admitted"); ok = false; }
  if nadm >= nprop {
    println("  FAIL: control did not fire — law J admitted everything"); ok = false;
  }
  println("   CONTROL law J rejected {nprop - nadm} of {nprop}");

  // ── 2. THE FRONTIER — law F, level by level ───────────────────────────────
  //
  // The real law F question: is `draw` INJECTIVE over the admitted set?  That is `field_norm` —
  // translation quotiented (placement is not the stencil's business), orientation NOT.  If two
  // canonical forms ever shared a `field_norm`, `rebuild` could not tell them apart and the
  // frontier would be BELOW that level.
  println("");
  println("2. THE FRONTIER — forms, shapes, and whether draw stays injective");
  println("   lvl  forms  shapes  distinct fields  injective?");
  nfrontier = 0;
  for ml in 1..4 {
    fs = forms_upto(ml);
    nlvl = len(fs);
    digs: vector<text> = [];
    norms: vector<text> = [];
    for fi in 0..nlvl {
      ff = fs[fi] ?? form_new(0, [], []);
      cc = hexset_chunk(Q0, R0, W, H);
      form_fill(ff, 0, 0, cc);
      digs += [digest_text(field_digest(cc))];
      norms += [field_norm_text(cc)];
    }
    nshape = 0;
    for si in 0..nlvl {
      f1 = true;
      for sk in 0..si { if (digs[sk] ?? "") == (digs[si] ?? "") { f1 = false; } }
      if f1 { nshape = nshape + 1; }
    }
    nnorm = 0;
    for ni in 0..nlvl {
      f2 = true;
      for nk in 0..ni { if (norms[nk] ?? "") == (norms[ni] ?? "") { f2 = false; } }
      if f2 { nnorm = nnorm + 1; }
    }
    inj = nnorm == nlvl;
    println("   {ml:>3} {nlvl:>6} {nshape:>7} {nnorm:>16}  {inj}");
    if !inj { nfrontier = nfrontier + 1; }
  }
  if nfrontier != 0 {
    println("  FAIL: `draw` is NOT injective at some level — the frontier is below it, and"
            + " `rebuild` cannot be exact there"); ok = false;
  }

  // ── 3. WHAT THE SHAPE-COLLISIONS ARE MADE OF ──────────────────────────────
  //
  // Forms grouped by `field_digest` are orientation-images by construction, so the question is
  // not WHETHER they are related but HOW — and the answer changes at level 2.
  //
  //   rotation  same turn sequence, different h0
  //   MIRROR    REVERSED turn sequence — the flip, one of the 12 orientations
  //
  // Level 1 has no mirrors: equal sides make every admitted form achiral. Unequal sides at
  // level 2 make chirality visible for the first time.
  println("");
  println("3. COLLISION STRUCTURE — rotations, and from level 2 also MIRRORS");
  println("   lvl  collisions  rotation  mirror  neither");
  nneither = 0;
  for pl in 1..4 {
    ps = forms_upto(pl);
    np = len(ps);
    pdigs: vector<text> = [];
    for pi in 0..np {
      pf = ps[pi] ?? form_new(0, [], []);
      pc = hexset_chunk(Q0, R0, W, H);
      form_fill(pf, 0, 0, pc);
      pdigs += [digest_text(field_digest(pc))];
    }
    nc = 0; nrot = 0; nmir = 0; nnei = 0;
    for ai in 0..np {
      for aj in 0..np {
        if ai < aj && (pdigs[ai] ?? "") == (pdigs[aj] ?? "") {
          nc = nc + 1;
          fa = ps[ai] ?? form_new(0, [], []);
          fb = ps[aj] ?? form_new(0, [], []);
          if turns_cyclic_eq(fa.fm_turn, fb.fm_turn) { nrot = nrot + 1; }
          else if turns_reverse_eq(fa.fm_turn, fb.fm_turn) { nmir = nmir + 1; }
          else { nnei = nnei + 1; }
        }
      }
    }
    println("   {pl:>3} {nc:>11} {nrot:>9} {nmir:>7} {nnei:>8}");
    nneither = nneither + nnei;
    if pl == 1 && nmir != 0 {
      println("  FAIL: level 1 reported a mirror pair — its forms are achiral"); ok = false;
    }
    if pl == 2 && nmir == 0 {
      println("  FAIL: level 2 reported NO mirror pair — chirality should appear with unequal"
              + " sides, so the mirror test is not working"); ok = false;
    }
  }
  println("   every collision is a rotation or a mirror: {nneither == 0}");
  if nneither != 0 {
    println("  FAIL: {nneither} shape-collisions are neither a rotation nor a mirror — two"
            + " unrelated cycles draw the same shape"); ok = false;
  }
  // CONTROL: the mirror test must be able to say NO, or "all explained" is free.
  println("   CONTROL is [3,4,5] the mirror of [3,4,5]? {turns_reverse_eq([3, 4, 5], [3, 4, 5])}"
          + "  of [3,5,4]? {turns_reverse_eq([3, 4, 5], [3, 5, 4])} (want false, true)");
  if turns_reverse_eq([3, 4, 5], [3, 4, 5]) {
    println("  FAIL: control did not fire — the mirror test accepts a non-mirror"); ok = false;
  }
  if !turns_reverse_eq([3, 4, 5], [3, 5, 4]) {
    println("  FAIL: the mirror test rejects a genuine mirror"); ok = false;
  }

  // ── 4. THE CONTROLS — the digest and the key must both be doing work ──────
  //
  // CONTROL A — a SUMMARY digest instead of the shape.  Keying the census on the cell COUNT is
  // the cheapest wrong thing to do, and it collides immediately: many distinct forms enclose the
  // same number of cells.
  println("");
  println("4. CONTROLS — the digest must be the shape, and the key must see the corners");
  cf2 = forms_upto(2);
  ncf = len(cf2);
  sdigs: vector<text> = [];
  cnts: vector<integer> = [];
  ckeys: vector<text> = [];
  nkeys: vector<text> = [];
  for ci2 in 0..ncf {
    cff = cf2[ci2] ?? form_new(0, [], []);
    ccc = hexset_chunk(Q0, R0, W, H);
    form_fill(cff, 0, 0, ccc);
    sdigs += [field_norm_text(ccc)];
    cnts += [count_digest(ccc)];
    ckeys += [form_key(cff)];
    nkeys += [form_key_noturn(cff)];
  }
  nreal = 0;
  for ri2 in 0..ncf {
    fr = true;
    for rk in 0..ri2 { if (sdigs[rk] ?? "") == (sdigs[ri2] ?? "") { fr = false; } }
    if fr { nreal = nreal + 1; }
  }
  ncount = 0;
  for bi in 0..ncf {
    fb2 = true;
    for bk in 0..bi { if (cnts[bk] ?? -1) == (cnts[bi] ?? -2) { fb2 = false; } }
    if fb2 { ncount = ncount + 1; }
  }
  println("   CONTROL A keyed on CELL COUNT: {ncount} classes, against {nreal} real fields");
  if ncount >= nreal {
    println("  FAIL: control did not fire — a cell-count key is as discriminating as the field,"
            + " so the digest is doing no work"); ok = false;
  }

  // CONTROL B — a TURN-BLIND identity.  `DESIGN.md` §9 names this one: drop the turn sequence
  // from the match key and distinct forms stop being distinguishable as forms.
  nfull = 0;
  nblind = 0;
  for fi2 in 0..ncf {
    ff2 = true;
    for fk in 0..fi2 { if (ckeys[fk] ?? "") == (ckeys[fi2] ?? "") { ff2 = false; } }
    if ff2 { nfull = nfull + 1; }
  }
  for gi in 0..ncf {
    fg = true;
    for gk in 0..gi { if (nkeys[gk] ?? "") == (nkeys[gi] ?? "") { fg = false; } }
    if fg { nblind = nblind + 1; }
  }
  println("   CONTROL B identities at level 2: {nfull} with turns, {nblind} without");
  if nblind >= nfull {
    println("  FAIL: control did not fire — dropping the turn sequence lost nothing"); ok = false;
  }

  println("");
  println("   FRONTIER: `draw` is injective at every level scanned, so law F holds and");
  println("   `rebuild` can be exact.  Length alone never collides; what unequal sides add is");
  println("   CHIRALITY, and a mirror is one of the 12 orientations.");

  // ── 5. A3 — THE SECOND GROWTH AXIS: SIDE COUNT ───────────────────────────
  //
  // A2 grew `len`; A3 grows the number of SIDES. Held at len 1 so the axis stays orthogonal to
  // A2's — and because growing BOTH at once is exactly what does not fit (section 6).
  println("");
  println("5. SIDE COUNT — 4 (a house's), 5, 6, at unit length");
  println("   sides  forms  shapes  distinct fields  injective?");
  nsidebad = 0;
  for sd in 3..7 {
    sf = forms_sides(sd, 1);
    ns2 = len(sf);
    sdigs: vector<text> = [];
    snorm: vector<text> = [];
    for sfi in 0..ns2 {
      sff = sf[sfi] ?? form_new(0, [], []);
      scc = hexset_chunk(Q0, R0, W, H);
      form_fill(sff, 0, 0, scc);
      sdigs += [digest_text(field_digest(scc))];
      snorm += [field_norm_text(scc)];
    }
    nsh = 0;
    for shi in 0..ns2 {
      fsh = true;
      for shk in 0..shi { if (sdigs[shk] ?? "") == (sdigs[shi] ?? "") { fsh = false; } }
      if fsh { nsh = nsh + 1; }
    }
    nnm = 0;
    for nmi in 0..ns2 {
      fnm = true;
      for nmk in 0..nmi { if (snorm[nmk] ?? "") == (snorm[nmi] ?? "") { fnm = false; } }
      if fnm { nnm = nnm + 1; }
    }
    sinj = nnm == ns2;
    println("   {sd:>5} {ns2:>6} {nsh:>7} {nnm:>16}  {sinj}");
    if !sinj { nsidebad = nsidebad + 1; }
    if ns2 <= 0 { println("  FAIL: no forms at {sd} sides"); ok = false; }
  }
  if nsidebad != 0 {
    println("  FAIL: `draw` is not injective at some side count — the frontier is below it");
    ok = false;
  }

  // ── 6. THE FRONTIER IS NOW COST, NOT CORRECTNESS ──────────────────────────
  //
  // The two axes MULTIPLY. Law F has not failed anywhere yet; what fails is the affordability of
  // deciding it exhaustively, and that is a frontier worth measuring rather than discovering by
  // a gate that quietly takes an hour.
  println("");
  println("6. THE COST FRONTIER — the two axes multiply");
  println("   sides x maxlen -> canonical forms");
  c31 = len(forms_sides(3, 1));
  c32 = len(forms_sides(3, 2));
  c41 = len(forms_sides(4, 1));
  c42 = len(forms_sides(4, 2));
  println("     3 x 1 -> {c31:>5}      3 x 2 -> {c32:>5}");
  println("     4 x 1 -> {c41:>5}      4 x 2 -> {c42:>5}");
  println("   measured out of gate (a probe, T2): 5x2 -> 372, 6x2 -> 900;");
  println("   sides 3-6 at maxlen 2 is 1442 forms and ~66 s just to ENUMERATE.");
  if c42 <= c41 {
    println("  FAIL: growing len did not grow the space — the axes are not independent"); ok = false;
  }
  println("   => enumerate-and-match recovery is affordable on ONE axis at a time. The 4-sided");
  println("      house [4,5,4,5] needs maxlen 5 (~1.2M proposals), so reaching it wants INDEXED");
  println("      recovery, not enumeration. That is the real limit this rung found.");

  // ── 7. A4 — LAW J IS NOT A SUFFICIENT ADMISSION RULE ─────────────────────
  //
  // A4 grows the space to REFLEX corners. Law J asks only that the walk closes, and that admits
  // two things it must not: non-simple walks (a repeated vertex, so "inside" is undefined) and
  // NON-CONVEX forms, which violate law F outright.
  //
  // This is the measurement that decides it: take every simple non-convex 4-sided form, draw it,
  // recover it, and see whether the recovered form is the SAME form. Where it is not — while the
  // recovery reproduces the field exactly (rho = 0) — two distinct forms draw one field, and NO
  // recovery method can separate them. A model-space limit, not a method limit.
  println("");
  println("7. A4 — non-convex forms VIOLATE law F, so law J alone cannot be the doorstep");
  println("   scale  simple non-convex  recovered  SAME FIELD, OTHER FORM  refused");
  nlawf = 0;
  for sc in 1..4 {
    ntot = 0; nrec = 0; nwrong = 0; nref = 0;
    for ci in 0..4913 {
      turns: vector<integer> = [];
      rest = ci; tot = 0;
      for tj in 0..3 {
        dg = ((rest % 17) ?? 0) - 5;
        rest = (rest / 17) ?? 0;
        turns += [dg]; tot = tot + dg;
      }
      lastt = 12 - tot;
      if lastt >= -5 && lastt <= 11 {
        turns += [lastt];
        lens: vector<integer> = [];
        for lj in 0..4 { lens += [sc * 2 - 1]; }
        af = form_new(0, lens, turns);
        if form_closes(af) && form_is_simple(af) && !form_is_convex(af) {
          ntot = ntot + 1;
          ac = hexset_chunk(-40, -40, 81, 81);
          form_fill(af, 0, 0, ac);
          ar = rebuild_construct(ac);
          if ar.rb_regime == 1 {
            if form_write(ar.rb_form, "z") == form_canon_text(af, "z") { nrec = nrec + 1; }
            else { nwrong = nwrong + 1; }
          } else { nref = nref + 1; }
        }
      }
    }
    println("   {sc * 2 - 1:>5} {ntot:>18} {nrec:>10} {nwrong:>23} {nref:>8}");
    nlawf = nlawf + nwrong;
    if ntot <= 0 { println("  FAIL: no simple non-convex forms found — A4 has nothing to say"); ok = false; }
  }
  // THE ASSERTION: admitting non-convex forms must be shown to BREAK law F. If it did not, the
  // convexity restriction would be unjustified and should be dropped.
  println("   law F violations found among non-convex forms: {nlawf}");
  if nlawf <= 0 {
    println("  FAIL: no non-convex form collided — the convexity restriction defends nothing"
            + " and must not be imposed"); ok = false;
  }
  // and the ADMISSIBLE set must be clean: every convex admitted form recovers as itself.
  ncvx = 0; ncvxbad = 0;
  cvf = forms_sides(4, 2);
  for vi in 0..len(cvf) {
    vf = cvf[vi] ?? form_new(0, [], []);
    if form_admissible(vf) {
      ncvx = ncvx + 1;
      vc = hexset_chunk(-40, -40, 81, 81);
      form_fill(vf, 0, 0, vc);
      vr = rebuild_construct(vc);
      if vr.rb_regime != 1 || form_write(vr.rb_form, "z") != form_canon_text(vf, "z") {
        ncvxbad = ncvxbad + 1;
      }
    }
  }
  println("   CONTROL the ADMISSIBLE (convex, simple) 4-sided set: {ncvx} forms,"
          + " {ncvxbad} that fail to recover as themselves");
  if ncvxbad != 0 {
    println("  FAIL: an admissible form does not recover as itself — the restriction is not"
            + " enough, or the recovery is wrong"); ok = false;
  }
  if ncvx <= 0 { println("  FAIL: the admissible set is empty"); ok = false; }
  println("   => `fits?` must refuse NON-CONVEX and NON-SIMPLE forms at the doorstep (K-FIT):");
  println("      they cannot be recovered even in principle, so they must never be authored.");

  println("");
  if ok { println("=== CENSUS OK ==="); }
  else { println("=== census test FAILED ==="); }
}
