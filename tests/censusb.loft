// censusb — THE GATE FOR THE DOMAIN-B CENSUS (`rt_census_b`, the `period` cost table).
// Every check has a control that must fire.
//
// `D` is CLOSED — all 24 directions are representable (`X3`) — so domain B's open constant was never
// representability but **COST**: what does each direction cost in PERIOD (how far a run must go
// before it lands back on a hex vertex) and in ANGLE ERROR (how far it sits from its nominal 15°·d)?
// A census REPORTS a table; the assertions pin its structure.
//
//   1  the cost table over all 24 — three period classes, and the even/odd angle split
//   2  the period, measured: it settles a 3× disagreement between two design docs
//   3  the `X31` ladder (T2 → T1) — today's in-between vector is DOMINATED, and a real trade exists
//
// The period primitives (`wall_run_len`, `wall_min_p`) are the gated ones, so the measurement
// decides; no doc number is copied in.
use hexwall;

const DEG = 57.29577951308232;      // 180/π
const SQ3 = 1.7320508075688772;

// A candidate in-between vector in doubled (k,m) coords: its N, angle and period.
//   N = (3k² + m²)/4      angle = atan2(m, k√3)      period = √N world units
// The N=21 row is anchored against the GATED direction 1 below, which is what ties this arithmetic
// to the measured lattice rather than to §10.9's table.
fn cand_n(k: integer, m: integer) -> integer { (3 * k * k + m * m) / 4 }
fn cand_angle(k: integer, m: integer) -> float {
  (atan2((m as float), (k as float) * SQ3) ?? 0.0) * DEG
}
fn cand_period(k: integer, m: integer) -> float { sqrt((cand_n(k, m) as float)) ?? 0.0 }

fn absf(v: float) -> float { if v < 0.0 { return 0.0 - v; } v }

fn main() {
  ok = true;
  println("=== domain-B census — the period cost table over D (rt_census_b) ===");

  // ── 1. THE COST TABLE ─────────────────────────────────────────────────────
  println("");
  println("1. THE COST TABLE — all 24 directions: angle error and period");
  println("    d  nominal   actual    error    period(wu)  min_p V1/V2");
  n_exact = 0; n_offby = 0; nbad = 0;
  p_edge = 0; p_vert = 0; p_between = 0;
  for d in 0..24 {
    nom = wall_angle_nominal(d);
    act = wall_angle_actual(d);
    err = act - nom;
    per = wall_run_len(d, 1);
    p1 = wall_min_p(d, 3, 0);
    p2 = wall_min_p(d, 0, 3);
    if d < 8 {
      println("   {d:>2} {nom:>8.3} {act:>8.3} {err:>8.3} {per:>11.4}      {p1}/{p2}");
    }
    if absf(err) < 0.0001 { n_exact = n_exact + 1; }
    else {
      if absf(absf(err) - 4.1066) < 0.001 { n_offby = n_offby + 1; }
      else { nbad = nbad + 1; }
    }
    // the three period classes
    if absf(per - SQ3) < 0.0001 { p_edge = p_edge + 1; }
    if absf(per - 1.0) < 0.0001 { p_vert = p_vert + 1; }
    if absf(per - 4.5826) < 0.001 { p_between = p_between + 1; }
  }
  println("   ... (24 rows; the pattern repeats every 4)");
  println("   angle: {n_exact} exact, {n_offby} off by 4.1066 deg, {nbad} neither");
  println("   period classes: {p_edge} at sqrt3, {p_vert} at 1, {p_between} at sqrt21");
  if n_exact != 12 || n_offby != 12 || nbad != 0 {
    println("  FAIL: the even/odd angle split is not 12 exact + 12 at 4.1066 deg (X29)"); ok = false;
  }
  if p_edge != 6 || p_vert != 6 || p_between != 12 {
    println("  FAIL: the period classes are not 6 / 6 / 12 — the cost table's shape is wrong");
    ok = false;
  }

  // ── 2. THE PERIOD, MEASURED — settling a 3x disagreement ───────────────────
  //
  // Two design docs disagree by exactly 3 on the in-between period, and a clean factor is the
  // signature of a counter bug, so the gated primitive decides.
  println("");
  println("2. THE PERIOD, MEASURED — the in-between 12");
  per1 = wall_run_len(1, 1);
  sq21 = sqrt(21.0) ?? 0.0;
  println("   direction 1: one period = {per1} wu = {per1 * 0.866} m");
  println("   sqrt(21) = {sq21} wu; DESIGN 10.9's ladder column says 1.528 wu = sqrt(21)/3");
  if absf(per1 - sq21) > 0.001 {
    println("  FAIL: the measured in-between period is not sqrt(21) wu"); ok = false;
  }
  if absf(per1 - sq21 / 3.0) < 0.001 {
    println("  FAIL: the measured period matched sqrt(21)/3 — then 10.10's 3.969 m is the wrong one");
    ok = false;
  }
  println("   => the measured period is sqrt(21) = 4.5826 wu = 3.969 m, agreeing with 10.10 and");
  println("      the gated doorstep; 10.9's ladder period column is 3x too small.");

  // ── 3. THE X31 LADDER — today's vector is DOMINATED ───────────────────────
  //
  // Candidates in doubled (k,m).  The N=21 row must reproduce the GATED direction-1 angle and
  // period, which is what anchors this arithmetic to the measured lattice.
  println("");
  println("3. THE LADDER (X31) — is today's in-between vector the best available?");
  println("    (k,m)      N   angle     err vs 15   period(wu)");
  a21 = cand_angle(5, 3);   p21 = cand_period(5, 3);
  a7  = cand_angle(3, 1);   p7  = cand_period(3, 1);
  a13 = cand_angle(4, 2);   p13 = cand_period(4, 2);
  a181 = cand_angle(15, 7); p181 = cand_period(15, 7);
  println("    (5,3)  {cand_n(5,3):>5} {a21:>8.3} {a21 - 15.0:>10.4} {p21:>11.4}   <- today");
  println("    (3,1)  {cand_n(3,1):>5} {a7:>8.3} {a7 - 15.0:>10.4} {p7:>11.4}");
  println("    (4,2)  {cand_n(4,2):>5} {a13:>8.3} {a13 - 15.0:>10.4} {p13:>11.4}");
  println("   (15,7)  {cand_n(15,7):>5} {a181:>8.3} {a181 - 15.0:>10.4} {p181:>11.4}");
  // the anchor: N=21 must BE the gated direction 1
  if cand_n(5, 3) != 21 || absf(a21 - wall_angle_actual(1)) > 0.001 || absf(p21 - per1) > 0.001 {
    println("  FAIL: the ladder's N=21 row does not reproduce the gated direction 1 — the ladder"
            + " arithmetic is not anchored to the measured lattice"); ok = false;
  }
  // (3,1): the SAME error magnitude, a shorter period -> today's choice is dominated
  same_err = absf(absf(a7 - 15.0) - absf(a21 - 15.0)) < 0.001;
  println("   (3,1) has the same |error| as today: {same_err}, and period {p7:.4} < {p21:.4}");
  if !same_err || p7 >= p21 {
    println("  FAIL: (3,1) does not dominate today's vector on period at equal error"); ok = false;
  }
  // (4,2): BOTH better -> dominated outright
  better_both = absf(a13 - 15.0) < absf(a21 - 15.0) && p13 < p21;
  println("   (4,2) is better on BOTH axes (angle and period): {better_both}");
  if !better_both {
    println("  FAIL: (4,2) does not dominate today's vector outright — X31's recommendation fails");
    ok = false;
  }
  // CONTROL: a genuine TRADE must exist, or "dominated" is a word with no content
  trade = absf(a181 - 15.0) < absf(a21 - 15.0) && p181 > p21;
  println("   CONTROL (15,7) is a genuine TRADE — better angle but LONGER period: {trade}"
          + " (so 'dominated' means something)");
  if !trade {
    println("  FAIL: control did not fire — every candidate dominated, so the ladder is not"
            + " measuring a trade-off at all"); ok = false;
  }

  println("");
  println("   X56: domain B's cost is a THREE-CLASS table — 6 directions at period sqrt3 (exact),");
  println("   6 at period 1 (exact), 12 at period sqrt21 = 3.969 m and 4.1066 deg off nominal. The");
  println("   in-between vector (5,3)/N=21 is DOMINATED: (3,1) matches its error at a 42% shorter");
  println("   period, (4,2) beats it on both. Changing it stays a live proposal (I-EXTEND).");

  println("");
  if ok { println("=== CENSUSB OK ==="); }
  else { println("=== censusb test FAILED ==="); }
}
