// wall — THE GATE FOR hexwall.  Every check has a control that must fire.
//
//   1   the 24 directions exist, and exactly 12 are exact
//   2   the in-between 12 are off their nominal angle by the SAME amount — recorded, not hidden
//   2b  the edge table agrees with the neighbour table — the check that caught a misfiled edge
//   3   a wall writes itself into the foxel's three wall slots per hex
//   3b  the field contains the wall, so every count below is over a window that clips nothing
//   4   writing is idempotent — an edge is stored once, by its owner
//   5   walls in all 24 directions all write, and none is empty
//   6   the marks run ALONG the wall, not across it (OD-12): one connected chain, not a comb
//   7   equal width provably cannot come from counting lattice rows
//   8   where a line may START and END — the editor's doorstep, per direction and class
//   9   an arbitrary plane point snapped to a legal line, checked against brute force
use hex_field;
use hex_grid;
use hexform;
use hexwall;

// The field is sized TO THE WALL, not guessed large.  A run of half-length `HALF` reaches
// `HALF + 1` world units from the origin (one circumradius past the ends), and a cell step is
// sqrt(3) in x and 1.5 in y — so 12 cells each way holds 20.8 x 18.0 wu, well past the longest
// run used here (half-length 12.0).  Section 3b PROVES the containment rather than assuming it:
// a larger window must find the same number of slots, or the window is clipping the wall.
const GQ = 25;
const GR = 25;
const Q0 = -12;
const R0 = -12;

// The oversized control window for the containment check.
const BQ = 45;
const BR = 45;
const BQ0 = -22;
const BR0 = -22;

// A window sized to the short vertex-anchored runs of section 6 (the longest, an N=21
// in-between run of three periods, reaches ~12 m ~ 8 hexes from the origin).
const SGQ = 29;
const SGR = 29;
const SQ0 = -14;
const SR0 = -14;

fn fabsf(v: float) -> float { if v < 0.0 { -v } else { v } }

fn main() {
  ok = true;
  println("=== hexwall — a straight wall, written into the foxel ===");

  // ── 1. THE 24 DIRECTIONS ──────────────────────────────────────────────────
  println("");
  println("1. DIRECTIONS — 24 of them; the even 12 are exact headings, the odd 12 are not");
  nexact = 0;
  for d in 0..24 { if wall_is_exact(d) { nexact = nexact + 1; } }
  println("   exact directions: {nexact} of 24");
  if nexact != 12 { println("  FAIL: expected 12 exact directions"); ok = false; }

  // ── 2. THE IN-BETWEEN OFFSET, MEASURED ────────────────────────────────────
  //
  // Two adjacent headings differ in length by sqrt(3), so one step of each does not bisect
  // the angle.  The offset is real and uniform; houses therefore use only the even 12.
  println("");
  println("2. THE IN-BETWEEN OFFSET — nominal vs actual, printed rather than hidden");
  println("   d24  nominal   actual    error   exact");
  worst_exact = 0.0;
  spread_lo = 999.0;
  spread_hi = -999.0;
  for da in 0..24 {
    nom = wall_angle_nominal(da);
    act = wall_angle_actual(da);
    err = act - nom;
    if err > 180.0 { err = err - 360.0; }
    if err < -180.0 { err = err + 360.0; }
    if wall_is_exact(da) {
      if fabsf(err) > worst_exact { worst_exact = fabsf(err); }
    } else {
      if fabsf(err) < spread_lo { spread_lo = fabsf(err); }
      if fabsf(err) > spread_hi { spread_hi = fabsf(err); }
    }
    println("   {da:>3} {nom:>8.2} {act:>8.2} {err:>+8.3}   {wall_is_exact(da)}");
  }
  println("   exact 12: worst error {worst_exact:6.4} deg");
  println("   in-between 12: error spans {spread_lo:6.4} .. {spread_hi:6.4} deg");
  if worst_exact > 0.000001 {
    println("  FAIL: an EVEN d24 is not an exact heading"); ok = false;
  }
  // CONTROL: the in-between offset must be NON-zero, or there is nothing to warn about
  if spread_lo < 0.001 {
    println("  FAIL: control did not fire — the in-between directions are exact after all,"
            + " so the houses-use-even-only rule defends nothing"); ok = false;
  }
  // and it must be the SAME offset on all 12 — a uniform bias, not scatter
  if spread_hi - spread_lo > 0.000001 {
    println("  FAIL: the in-between offset is not uniform across the 12"); ok = false;
  }

  // ── 2b. THE EDGE TABLE AGREES WITH THE NEIGHBOUR TABLE ────────────────────
  //
  // A wall mark says "this edge, between these two cells".  If the corner pair and the
  // neighbour disagree, the mark lands on a real edge that is simply the WRONG one — and
  // every other check here still passes, because a consistently wrong edge is written
  // once, is idempotent and is non-empty.  This is the only check that sees it.
  //
  // It is a real defect caught, not a hypothetical: this file's first version paired its
  // own 30-degree corner table with hex_field's `nb_q/nb_r`, whose direction order is
  // [E, W, SE, SW, NE, NW] against hex_grid's [E, SE, SW, W, NW, NE].  Five of six edges
  // were misfiled and the gate was green.
  println("");
  println("2b. EDGE TABLE — every edge midpoint sits halfway between the cells it separates");
  worst_gap = 0.0;
  for gr in -3..4 {
    for gq in -3..4 {
      for gd in 0..6 {
        gp = wall_edge_gap(gq, gr, gd);
        if gp > worst_gap { worst_gap = gp; }
      }
    }
  }
  println("   worst gap over 49 cells x 6 directions: {worst_gap:8.6} wu");
  if worst_gap > 0.000001 {
    println("  FAIL: the edge table and the neighbour table disagree — marks are misfiled");
    ok = false;
  }
  // CONTROL: the measure must be able to SEE a disagreement, or a zero proves nothing.
  // Pair each edge with the NEXT direction's neighbour and the gap must become large.
  ctl_gap = 0.0;
  for cr in -3..4 {
    for cq in -3..4 {
      for cd in 0..6 {
        (ce1, ce2) = hex_edge_corners(cd);
        cmx = (hex_corner_x(cq, cr, ce1) + hex_corner_x(cq, cr, ce2)) / 2.0;
        cmy = (hex_corner_y(cq, cr, ce1) + hex_corner_y(cq, cr, ce2)) / 2.0;
        (cnq, cnr) = hex_neighbor(cq, cr, (cd + 1) % 6);
        chx = (cell_x_w(cq, cr) + cell_x_w(cnq, cnr)) / 2.0;
        chy = (cell_y_w(cq, cr) + cell_y_w(cnq, cnr)) / 2.0;
        cg = sqrt((cmx - chx) * (cmx - chx) + (cmy - chy) * (cmy - chy)) ?? 0.0;
        if cg > ctl_gap { ctl_gap = cg; }
      }
    }
  }
  println("   CONTROL misfiled by one direction: gap {ctl_gap:8.6} wu");
  if ctl_gap < 0.1 {
    println("  FAIL: control did not fire — the gap measure cannot see a misfiled edge");
    ok = false;
  }

  // ── 3. A WALL WRITES ITSELF INTO THE FOXEL ────────────────────────────────
  println("");
  println("3. WRITE — a wall marks every hex edge its band crosses, and nothing else");
  eg = edgeset_new(Q0, R0, GQ, GR);
  w0 = wall_new(0, 0.0, 0.0, 12.0, 7);
  n0 = wall_write(w0, eg, Q0, R0, GQ, GR);
  println("   d24=0, half-length 12.0 wu -> {n0} wall slots set");
  if n0 <= 0 { println("  FAIL: the wall wrote nothing"); ok = false; }

  // ── 3b. THE FIELD CONTAINS THE WALL ───────────────────────────────────────
  //
  // Every count below is a count over a WINDOW.  A window too small does not error — it
  // silently returns fewer slots, and every ratio built on it is then wrong by an unknown
  // amount.  So the window is checked, not assumed: a field nearly twice as wide must find
  // exactly the same slots.
  println("");
  println("3b. CONTAINMENT — a larger field finds the same wall, so the window clips nothing");
  ebig = edgeset_new(BQ0, BR0, BQ, BR);
  nbig = wall_write(w0, ebig, BQ0, BR0, BQ, BR);
  println("   {GQ}x{GR} window -> {n0} slots;  {BQ}x{BR} window -> {nbig} slots");
  if nbig != n0 {
    println("  FAIL: the window clips the wall — {nbig} slots exist but only {n0} were seen");
    ok = false;
  }

  // ── 4. IDEMPOTENT ─────────────────────────────────────────────────────────
  //
  // An edge is stored ONCE, under the cell that owns it, so writing the same wall again
  // must add nothing.  That is what makes three-slots-per-hex a consistent store.
  n1 = wall_write(w0, eg, Q0, R0, GQ, GR);
  println("   writing the same wall again -> {n1} new slots (must be 0)");
  if n1 != 0 { println("  FAIL: writing is not idempotent — an edge got two owners"); ok = false; }

  // CONTROL: a DIFFERENT wall must still write, or the check above is vacuous
  eg2 = edgeset_new(Q0, R0, GQ, GR);
  w90 = wall_new(6, 0.0, 0.0, 12.0, 7);
  n2 = wall_write(w90, eg2, Q0, R0, GQ, GR);
  println("   CONTROL a different direction into a fresh field -> {n2} slots");
  if n2 <= 0 { println("  FAIL: control did not fire"); ok = false; }

  // ── 5. ALL 24 DIRECTIONS WRITE ────────────────────────────────────────────
  println("");
  println("5. ALL 24 — every direction produces a wall");
  println("   d24  slots  exact");
  nempty = 0;
  for db in 0..24 {
    ge = edgeset_new(Q0, R0, GQ, GR);
    wb = wall_new(db, 0.0, 0.0, 12.0, 7);
    nb = wall_write(wb, ge, Q0, R0, GQ, GR);
    println("   {db:>3} {nb:>6}   {wall_is_exact(db)}");
    if nb <= 0 { nempty = nempty + 1; }
  }
  if nempty != 0 { println("  FAIL: {nempty} directions wrote nothing"); ok = false; }

  // ── 6. THE MARKS RUN ALONG THE WALL, AND FORM ONE CHAIN (OD-12) ───────────
  //
  // OD-12: `wall_write` first marked the edges the band CROSSES — the roughly perpendicular
  // ones — so a wall evaluated to a comb of pickets across itself. The fix marks the edges
  // that SEPARATE the wall's two sides (`wall_separates`), which is the boundary between two
  // half-planes: one connected chain running ALONG the line. This section proves both
  // properties, because the perpendicular STRAY cannot tell them apart — a comb and a zigzag
  // both swing ~1 hex off the line.
  //
  // Walls are anchored on a VERTEX and run a legal number of periods (`wall_from_run`), so the
  // chain terminates cleanly at both ends. The window is sized to the run.
  //
  // THE INVARIANT IS CONNECTIVITY. A picket comb and an along-chain both swing ~1 hex off the
  // line, so the perpendicular stray cannot tell them apart. What can: the chain is ONE
  // connected path (exactly two ends, no branch), where the comb is k disjoint edges (2k ends).
  // The `|C->N . dir|` column is secondary — it shows the marked edges point ACROSS the wall
  // (C->N along it would be a picket) — but a shallow in-between wall zigzags, so its worst
  // single edge can run steep; connectivity is what is asserted, not a dot threshold.
  //
  // First, the ACROSS reference: a hand-built picket comb (vertical edges along a horizontal
  // wall). Every check below is measured against it, so the numbers are not free-floating.
  cpick = edgeset_new(SQ0, SR0, SGQ, SGR);
  for cy in -4..5 {
    edge_set_mat(cpick, cy, 0, nb_q(cy, 0, 0), nb_r(cy, 0, 0), 7);   // dir 0 = E, a vertical edge
  }
  whoriz = wall_from_run(0, 3, 0, wall_min_p(0, 3, 0) * 3, 7);
  pick_along = wall_along_max(whoriz, cpick, SQ0, SR0, SGQ, SGR);
  pick_ends = wall_chain_ends(cpick, SQ0, SR0, SGQ, SGR);

  println("");
  println("6. ALONG NOT ACROSS — the marks run along the wall and form ONE connected chain");
  println("   the ACROSS reference (a picket comb): |C->N.dir| {pick_along:4.2}, "
          + "chain-ends {pick_ends}");
  println("   d24  edges  |C->N.dir|  chain-ends  branches  stray/halfw   one-chain?");
  worst_along = 0.0;
  worst_ratio = 0.0;
  nnotchain = 0;
  for dm in 0..24 {
    gm = edgeset_new(SQ0, SR0, SGQ, SGR);
    pm = wall_min_p(dm, 3, 0);
    wm = wall_from_run(dm, 3, 0, pm * 3, 7);
    ne6 = wall_write(wm, gm, SQ0, SR0, SGQ, SGR);
    alng = wall_along_max(wm, gm, SQ0, SR0, SGQ, SGR);
    ends = wall_chain_ends(gm, SQ0, SR0, SGQ, SGR);
    brn = wall_chain_branches(gm, SQ0, SR0, SGQ, SGR);
    stray = wall_mesh_stray(wm, gm, SQ0, SR0, SGQ, SGR);
    ratio = (stray / (WALL_W * 0.5)) ?? 0.0;
    if alng > worst_along { worst_along = alng; }
    if ratio > worst_ratio { worst_ratio = ratio; }
    ischain = ends == 2 && brn == 0;
    if !ischain { nnotchain = nnotchain + 1; }
    println("   {dm:>3} {ne6:>6} {alng:>11.3} {ends:>12} {brn:>9} {ratio:>12.2}   {ischain}");
    if ne6 <= 0 { println("  FAIL: d24={dm} wrote nothing"); ok = false; }
  }
  println("   worst |C->N.dir| = {worst_along:5.3}  (the picket reference is {pick_along:4.2})");
  println("   worst stray = {worst_ratio:5.2}x the wall half-width (rebuild must undo this)");

  // THE ASSERTION: every wall is ONE simple chain — exactly two ends, no branch. This is the
  // whole of OD-12: a chain runs along the line, a comb sits across it.
  if nnotchain != 0 {
    println("  FAIL: {nnotchain} of 24 walls are not a single connected chain (OD-12)"); ok = false;
  }
  // and every wall must be strictly LESS across than a pure picket comb.
  if worst_along >= pick_along {
    println("  FAIL: a wall is as across as a picket comb — the marks are not along the line");
    ok = false;
  }

  // CONTROL A: the measurements must be able to SEE across/disconnected, or the passes above
  // prove nothing. The picket reference must read |dot| ~ 1 and many ends.
  println("   CONTROL the picket comb reads |dot| {pick_along:4.2} and {pick_ends} ends"
          + " (want ~1.0 and >> 2)");
  if pick_along < 0.99 {
    println("  FAIL: control did not fire — the along-test cannot see an across edge"); ok = false;
  }
  if pick_ends <= 2 {
    println("  FAIL: control did not fire — the chain check cannot see a disconnected comb");
    ok = false;
  }
  // CONTROL B: breaking one INTERIOR edge of a real chain must split it, 2 ends -> 4. An END
  // edge would only shorten it (still 2), so the removed edge is chosen at the middle of the run.
  cbrk = edgeset_new(SQ0, SR0, SGQ, SGR);
  wbrk = wall_from_run(1, 3, 0, wall_min_p(1, 3, 0) * 3, 7);
  tot_edges = wall_write(wbrk, cbrk, SQ0, SR0, SGQ, SGR);
  ends_whole = wall_chain_ends(cbrk, SQ0, SR0, SGQ, SGR);
  // the edge nearest the run's CENTRE — guaranteed interior, so removing it splits the chain
  rmq = 0; rmr = 0; rmd = -1; bestd2 = 1.0e30;
  for br in SR0..SR0 + SGR {
    for bq in SQ0..SQ0 + SGQ {
      for bd in 0..3 {
        (bnq, bnr) = hex_neighbor(bq, br, bd);
        if edge_mat(cbrk, bq, br, bnq, bnr) != 0 {
          mx = (cell_x_w(bq, br) + cell_x_w(bnq, bnr)) * 0.5 - wbrk.wa_ox;
          my = (cell_y_w(bq, br) + cell_y_w(bnq, bnr)) * 0.5 - wbrk.wa_oy;
          d2 = mx * mx + my * my;
          if d2 < bestd2 { bestd2 = d2; rmq = bq; rmr = br; rmd = bd; }
        }
      }
    }
  }
  if rmd >= 0 {
    edge_set_mat(cbrk, rmq, rmr, nb_q(rmq, rmr, rmd), nb_r(rmq, rmr, rmd), 0);
  }
  ends_broken = wall_chain_ends(cbrk, SQ0, SR0, SGQ, SGR);
  println("   CONTROL break the centre edge (of {tot_edges}): chain-ends {ends_whole} -> "
          + "{ends_broken} (want 2 -> 4)");
  if !(ends_whole == 2 && ends_broken == 4) {
    println("  FAIL: control did not fire — removing an interior edge did not split the chain");
    ok = false;
  }

  // ── 7. EXACTLY STRAIGHT, EXACTLY THE SAME WIDTH — what is and is not possible ──
  //
  // The question this section answers: can all 24 walls be exactly straight AND exactly the
  // same width?  Straightness is free — a straight line is straight at any angle.  Equal
  // WIDTH is where it is decided, and the answer is an integer fact, not a measurement.
  //
  // A wall whose faces lie on LATTICE LINES has a width that is an integer multiple of that
  // direction's line spacing, S*sqrt(3)/(2*sqrt(N)) with N = a^2+ab+b^2.  Two such widths
  // can be equal only if sqrt(N2/N1) is rational — i.e. only if N1*N2 is a perfect square.
  println("");
  println("7. WIDTH — can equal width come from counting lattice rows?");
  println("   d24   tri vector    N = |v|^2/S^2   exact");
  for dn in 0..24 {
    println("   {dn:>3}  ({tri_a(dn):>3},{tri_b(dn):>3})    {tri_n2(dn):>11}   {wall_is_exact(dn)}");
  }
  // Collect the distinct N values, then test every pair.
  nclass: vector<integer> = [];
  for dc in 0..24 {
    nv = tri_n2(dc);
    seen = false;
    for si in 0..len(nclass) { if (nclass[si] ?? -1) == nv { seen = true; } }
    if !seen { nclass += [nv]; }
  }
  println("   distinct N among the 24: {len(nclass)}");
  ncomm = 0;
  for ia in 0..len(nclass) {
    for ib in 0..len(nclass) {
      if ia < ib {
        na = nclass[ia] ?? 0;
        nb2 = nclass[ib] ?? 0;
        cm = commensurable(na, nb2);
        println("   N={na} vs N={nb2}: N1*N2 = {na * nb2}, a perfect square? {cm}");
        if cm { ncomm = ncomm + 1; }
      }
    }
  }
  if ncomm != 0 {
    println("  FAIL: two direction classes ARE commensurable — equal width by counting rows"
            + " would be possible, and the width-is-a-model-constant rule loses its reason");
    ok = false;
  } else {
    println("   => NO pair is commensurable: equal width CANNOT come from counting rows.");
    println("      Width must be a model constant applied perpendicular to the centreline,");
    println("      and the cells are its rasterisation — never the other way round.");
  }
  // CONTROL: the test must be able to say YES. A class against ITSELF is commensurable
  // (ratio 1), so if that comes back false the predicate is broken and the zero above is
  // meaningless.
  ctl_ok = true;
  for ic in 0..len(nclass) {
    nc = nclass[ic] ?? 0;
    if !commensurable(nc, nc) { ctl_ok = false; }
  }
  println("   CONTROL every class is commensurable with itself: {ctl_ok}");
  if !ctl_ok {
    println("  FAIL: control did not fire — the commensurability predicate cannot say YES");
    ok = false;
  }

  // ── 8. WHERE A LINE MAY START AND END — the editor's doorstep ─────────────
  //
  // The mesh is built from whole hex edges, so its ends are hex VERTICES: an endpoint
  // anywhere else cannot be represented and the rebuilt wall would stop somewhere the
  // editor did not put it. This section derives the admissible endpoints per direction
  // and per start-vertex class, which is exactly what the editor must enforce (K-FIT).
  println("");
  println("8. ENDPOINTS — which runs land on a hex vertex, per direction and start class");
  println("   V1 = (3,0) is a class-1 vertex, V2 = (0,3) is class 2, C = (0,0) is a centre");
  println("   d24    N   step(m)   p admissible from V1 (p=1..9)   from V2");
  nbad = 0;
  for de in 0..24 {
    p1 = "";
    p2 = "";
    for pe in 1..10 {
      p1 = p1 + (if wall_run_ok(de, 3, 0, pe) { "#" } else { "." });
      p2 = p2 + (if wall_run_ok(de, 0, 3, pe) { "#" } else { "." });
    }
    // count how many of the nine are admissible from each class
    c1 = 0;
    c2 = 0;
    for pf in 1..10 {
      if wall_run_ok(de, 3, 0, pf) { c1 = c1 + 1; }
      if wall_run_ok(de, 0, 3, pf) { c2 = c2 + 1; }
    }
    stepm = wall_run_len(de, wall_min_p(de, 3, 0)) * 0.8660254037844386;
    println("   {de:>3} {tri_n2(de):>4} {stepm:>9.4} {p1:>16}  {p2:>10}   [{c1}/9, {c2}/9]");
    // THE LAW: shift 0 => all nine work from both classes; otherwise exactly six of nine
    shift = ((tri_a(de) - tri_b(de)) % 3 + 3) % 3;
    if shift == 0 {
      if c1 != 9 || c2 != 9 {
        println("  FAIL: d24={de} has a class-preserving period but not every run lands");
        nbad = nbad + 1;
      }
    } else {
      if c1 != 6 || c2 != 6 {
        println("  FAIL: d24={de} should admit exactly 6 of 9, got {c1}/{c2}");
        nbad = nbad + 1;
      }
    }
  }
  if nbad != 0 { ok = false; }

  // The three quantisation classes, in metres — what the editor actually snaps to.
  println("");
  println("   the three endpoint quantisations (SPEC L8: 1 wu = 0.866 m):");
  println("     N=3  (0/60/120/...)   step {wall_run_len(0, 1) * 0.8660254037844386:6.4} m"
          + "  — one hex step, every multiple, from any vertex");
  println("     N=1  (30/90/150/...)  step {wall_run_len(2, 1) * 0.8660254037844386:6.4} m"
          + "  — but 1 in 3 is a hex CENTRE and is refused");
  println("     N=39 (the odd 12)     step {wall_run_len(1, 1) * 0.8660254037844386:6.4} m"
          + "  — every multiple (delta 0), and far too coarse for a building");

  // CONTROL 1: a start that is a hex CENTRE must be refused outright, in every direction.
  ncentre = 0;
  for dg in 0..24 { if wall_run_ok(dg, 0, 0, 1) { ncentre = ncentre + 1; } }
  println("   CONTROL runs starting at a hex CENTRE that were accepted: {ncentre} (must be 0)");
  if ncentre != 0 {
    println("  FAIL: a centre was accepted as an endpoint — the mesh cannot end there"); ok = false;
  }
  // CONTROL 2: the refusal must be able to fire at all — on an N=1 direction some p is
  // rejected, and `wall_snap_p` must offer a DIFFERENT, admissible one.
  bad_p = 0;
  for ph in 1..10 { if !wall_run_ok(2, 3, 0, ph) { bad_p = ph; } }
  snapped = wall_snap_p(2, 3, 0, bad_p);
  println("   CONTROL d24=2 refuses p={bad_p}; snap offers p={snapped}");
  if bad_p == 0 {
    println("  FAIL: control did not fire — no run was refused, so the doorstep is vacuous");
    ok = false;
  }
  if snapped == bad_p || snapped == 0 || !wall_run_ok(2, 3, 0, snapped) {
    println("  FAIL: the snap did not offer a different admissible run"); ok = false;
  }

  // ── 9. FROM AN ARBITRARY MOUSE POINT TO A LEGAL LINE ──────────────────────
  //
  // Two snaps: an arbitrary point to the nearest hex VERTEX, then an arbitrary target to
  // the nearest legal endpoint over all 24 directions. Both are checked against BRUTE
  // FORCE over the neighbourhood — the closed form must agree with exhaustive search, or
  // it is just a plausible-looking heuristic.
  println("");
  println("9. SNAP — arbitrary plane point -> nearest vertex -> nearest legal line");
  println("      point (x,y)      -> vertex (a,b)   dist    brute-force agrees");
  nsnap = 0;
  nfar = 0;
  for sx in 0..7 {
    for sy in 0..7 {
      // deliberately irrational-ish offsets so nothing lands on a lattice point by luck
      px2 = (sx as float) * 0.9137 - 2.5;
      py2 = (sy as float) * 0.7913 - 2.5;
      (va, vb) = nearest_vertex(px2, py2);
      if !tri_is_vertex(va, vb) {
        println("  FAIL: snap returned a non-vertex at ({px2:5.3},{py2:5.3})"); ok = false;
      }
      dx2 = tri_x(va, vb) - px2;
      dy2 = tri_y(va, vb) - py2;
      dsn = sqrt(dx2 * dx2 + dy2 * dy2) ?? 0.0;
      // BRUTE FORCE: every hex-scale point in a wide box; the closed form must find the best
      bf = 1.0e30;
      for bi in -8..9 {
        for bj in -8..9 {
          ba2 = 3 * bi;
          bb2 = 3 * bj;
          if tri_is_vertex(ba2, bb2) {
            ex = tri_x(ba2, bb2) - px2;
            ey = tri_y(ba2, bb2) - py2;
            e2 = sqrt(ex * ex + ey * ey) ?? 0.0;
            if e2 < bf { bf = e2; }
          }
        }
      }
      if dsn > bf + 0.000001 { nsnap = nsnap + 1; }
      if sx == 3 && sy < 3 {
        println("   ({px2:7.4},{py2:7.4}) -> ({va:>3},{vb:>3}) {dsn:7.4}   "
                + "brute {bf:7.4}  {dsn <= bf + 0.000001}");
      }
    }
  }
  println("   49 arbitrary points snapped; disagreements with brute force: {nsnap}");
  if nsnap != 0 {
    println("  FAIL: the vertex snap is not the nearest vertex"); ok = false;
  }
  // CONTROL: the naive snap — round to hex scale and STOP — must land on centres, or the
  // six-neighbour fix-up above is defending nothing.
  ncent = 0;
  for cx in 0..7 {
    for cy in 0..7 {
      qx = (cx as float) * 0.9137 - 2.5;
      qy = (cy as float) * 0.7913 - 2.5;
      (ra, rb) = hex_scale_round(qx, qy);
      if !tri_is_vertex(ra, rb) { ncent = ncent + 1; }
    }
  }
  println("   CONTROL naive round-and-stop landed on a hex CENTRE {ncent} of 49 times");
  if ncent == 0 {
    println("  FAIL: control did not fire — rounding never hits a centre, so the"
            + " neighbour fix-up is untested"); ok = false;
  }

  // The far end: an arbitrary target -> the best legal line from a fixed anchor.
  println("");
  println("   anchor (3,0). target -> chosen direction, periods, endpoint, residual");
  for tj in 0..6 {
    tx2 = 4.0 + (tj as float) * 1.31;
    ty2 = 1.7 + (tj as float) * 0.77;
    bd = snap_run_d24(3, 0, tx2, ty2);
    if bd < 0 {
      println("  FAIL: no legal line found toward ({tx2:5.2},{ty2:5.2})"); ok = false;
    } else {
      bp = snap_run_p(bd, 3, 0, tx2, ty2);
      rd = run_end_dist(bd, 3, 0, bp, tx2, ty2);
      // BRUTE FORCE over every direction and every p in range
      bfd = 1.0e30;
      for gd in 0..24 {
        for gpp in 1..14 {
          if wall_run_ok(gd, 3, 0, gpp) {
            gg = run_end_dist(gd, 3, 0, gpp, tx2, ty2);
            if gg < bfd { bfd = gg; }
          }
        }
      }
      println("   ({tx2:5.2},{ty2:5.2}) -> d24={bd:>2} p={bp:>2} end=({wall_end_a(bd,3,bp):>3},"
              + "{wall_end_b(bd,0,bp):>3}) residual {rd:6.4}  brute {bfd:6.4}");
      if !wall_run_ok(bd, 3, 0, bp) {
        println("  FAIL: the chosen run is not admissible"); ok = false;
      }
      if rd > bfd + 0.000001 { nfar = nfar + 1; }
    }
  }
  if nfar != 0 {
    println("  FAIL: {nfar} targets got a worse line than brute force found"); ok = false;
  }

  println("");
  if ok { println("=== WALL OK ==="); }
  else { println("=== wall test FAILED ==="); }
}
