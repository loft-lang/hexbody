// housetest — THE SAME HOUSE, DRAWN IN 12 DIRECTIONS.
//
// The 12 orientations are 6 rotations x {identity, mirror} — the D6 the lattice has.
// This gate draws ONE house specification at all 12 and asks whether what comes out is
// the same house moved, in every layer that carries it: the floor cells, the wall edges,
// and the openings placed on those walls.
//
// EVERY GATE HERE HAS A CONTROL THAT MUST FIRE.  A gate without a demonstrated failure
// mode does not count — and two of the obvious ones cannot see the fault they sit next
// to (see gates 2 and 5).
use hex_field;
use hexway;
use hexroof;
use housedraw;

const Q0 = -20;
const R0 = -20;
const GW = 41;
const GH = 41;

const FLOOR_BOARD = 3;
const WALL_COTTAGE = 7;

fn fabs2(v: float) -> float { if v < 0.0 { -v } else { v } }

// The world image of a cell under orientation (n, mir).
fn move_q(q: integer, r: integer, n: integer, m: boolean) -> integer {
  (aq, ar) = cell_rot(q, r, n);
  if m { (bq, br) = cell_mirror(aq, ar); return bq; }
  aq
}
fn move_r(q: integer, r: integer, n: integer, m: boolean) -> integer {
  (aq, ar) = cell_rot(q, r, n);
  if m { (bq, br) = cell_mirror(aq, ar); return br; }
  ar
}

// A world mirror is W.R(t) = R(-t).W, so the SPEC rotation for the mirrored
// comparison is -n, not n.
// The explicit `return` is a WORKAROUND, not a style choice: `%` as the tail expression
// of an if-branch in an integer-returning fn makes the native generator emit `as i8` and
// rustc rejects it (E0308, expected i64 found i8). Interpreter is fine; --native will not
// compile. An early `return` sidesteps it. Repro: LOFT-HANDOFF.md -> N1.
fn spec_rot(n: integer, m: boolean) -> integer {
  if m { return ((-n) % 6 + 6) % 6; }
  n
}

fn main() {
  println("=== story house test — 12 orientations ===");
  ok = true;

  // ── 0. the concrete end result: one house, rot 0 ──────────────────────────
  base = plan_new(0, 0, 5, 4, 0, false);
  cells = hexset_chunk(Q0, R0, GW, GH);
  types = labels_new(Q0, R0, GW, GH);
  edges = edgeset_new(Q0, R0, GW, GH);
  nfloor = draw_floor(base, cells, types, FLOOR_BOARD);
  nwall = draw_walls(cells, edges, WALL_COTTAGE);
  println("floor {nfloor} cells = {(nfloor as float) * 1.949:5.1} m2"
          + "   wall {nwall} edges = {(nwall as float) * 0.866:5.1} m of run");
  if nfloor != 27 { println("  FAIL: expected 27 floor cells"); ok = false; }
  if nwall != 38 { println("  FAIL: expected 38 boundary edges"); ok = false; }

  // A thin wall is a STRIP OF HEX EDGES, not a line, so its run is longer than the wall
  // it stands on.  Section 7 measures both exact overheads.
  side3 = side_edges(base, cells, 3);
  nlen = (side_run_len(side3) as float) * 0.866;
  wlen = (5 as float) * 1.5;
  println("side 3 is {wlen:4.2} m of wall carried by {side_run_len(side3)} edges"
          + " = {nlen:5.2} m of run ({(nlen / wlen * 100.0 - 100.0) ?? 0.0:3.0}% longer)");

  // ── 1. the floor, as a picture ────────────────────────────────────────────
  println("");
  println("  # wall cell   . floor   (rot 0)");
  print_plan(cells);

  // ── 2. EQUIVARIANCE: cells AND edges, all 12 orientations ─────────────────
  //
  // Compare a house drawn AT orientation g against the house drawn at identity and
  // then MOVED by the library's own cell_rot / cell_mirror.  Edges must be compared
  // too: a check on cells alone passes on a wall that was silently dropped.
  println("");
  println("2. EQUIVARIANCE — the same house drawn at g, vs the identity house moved by g");
  bad = 0;
  for n in 0..6 {
    for mi in 0..2 {
      m = mi == 1;
      pg = plan_new(0, 0, 5, 4, spec_rot(n, m), m);
      gc = hexset_chunk(Q0, R0, GW, GH);
      gt = labels_new(Q0, R0, GW, GH);
      ge = edgeset_new(Q0, R0, GW, GH);
      draw_floor(pg, gc, gt, FLOOR_BOARD);
      draw_walls(gc, ge, WALL_COTTAGE);
      diff = compare_moved(cells, edges, gc, ge, n, m);
      if diff != 0 { bad = bad + 1; }
      println("   rot {n} mir {m}   floor {hexset_count(gc)}"
              + "   edges {edgeset_count_all(ge)}   mismatched {diff}");
    }
  }
  if bad != 0 { println("  FAIL: {bad} of 12 orientations are not equivariant"); ok = false; }
  else { println("   -> 12/12 equivariant, cells and edges"); }

  // CONTROL: the index-space rectangle — today's stamp_house — must FAIL this.
  // The real control: an index-space rectangle is not mirror-closed — its mirror is
  // not any index-space rectangle, at either row parity.
  mirror_closed = index_rect_mirror_closed();
  println("   CONTROL index-space rectangle: mirror-closed = {mirror_closed}");
  if mirror_closed { println("  FAIL: control did not fire"); ok = false; }

  // ── 3. OPENINGS: a door annotates edges, a window alters no cells ─────────
  println("");
  println("3. OPENINGS — a door is N EDGES at t; nothing is deleted");
  before_cells = hexset_count(cells);
  before_edges = edgeset_count_all(edges);
  nd = place_opening(base, cells, edges, 3, 0.5, 1, OPEN_DOOR);
  nw2 = place_opening(base, cells, edges, 3, 0.2, 1, OPEN_WINDOW);
  println("   door {nd} edge(s) = {(nd as float) * 0.866:4.2} m clear"
          + "   window {nw2} edge(s)");
  println("   floor {before_cells} -> {hexset_count(cells)}"
          + "   wall edges {before_edges} -> {edgeset_count_all(edges)}");
  if hexset_count(cells) != before_cells {
    println("  FAIL: an opening changed the floor"); ok = false;
  }
  if edgeset_count_all(edges) != before_edges {
    println("  FAIL: an opening deleted wall edges — the run will fragment"); ok = false;
  }
  if nd != 1 { println("  FAIL: door did not open exactly 1 edge"); ok = false; }

  // ── 4. THE ROOF ───────────────────────────────────────────────────────────
  println("");
  println("4. ROOF — a gable over the massing plus one halo ring");
  roofset = hexset_chunk(Q0, R0, GW, GH);
  grow_ring(cells, roofset);
  hz = heights_new(Q0, R0, GW, GH);
  draw_roof(base, roofset, hz, 2.54, 1.0, 0);
  ridge_z = height_get(hz, 0, 0);
  ponds = roof_ponds(roofset, hz);
  println("   roof field {hexset_count(roofset)} cells (massing {hexset_count(cells)}"
          + " + one ring)   ridge {ridge_z:4.2} = {ridge_z * 0.866:4.2} m");
  if ponds != 0 { println("  FAIL: the roof ponds"); ok = false; }

  // THE EAVE IS THE LONG SIDES ONLY.  hexroof::eave_spread over the whole boundary of a
  // GABLE reads the full ridge-to-eave range by design — the gable ends rise linearly,
  // that is what makes them gables.  Reading it over the halo ring instead measures a
  // ring one cell OUT from the eave and is meaningless (it reports 4.50).  The eave
  // proper is the boundary on sides 1 and 3, and it must be dead level.
  elo = 1000000.0;
  ehi = -1000000.0;
  for es in 0..4 {
    if es == 1 || es == 3 {
      esr = side_edges(base, cells, es);
      for eei in 0..side_run_len(esr) {
        ez = height_get(hz, esr.sr_qa[eei] ?? 0, esr.sr_ra[eei] ?? 0);
        if ez < elo { elo = ez; }
        if ez > ehi { ehi = ez; }
      }
    }
  }
  println("   eave on the long sides: {elo:4.2} .. {ehi:4.2}"
          + "   spread {ehi - elo:6.4}   ({elo * 0.866:4.2} m)");
  println("   CONTROL whole-boundary spread (a gable end is SUPPOSED to rise):"
          + " {eave_spread(cells, hz):6.4}");
  if ehi - elo > 0.0001 { println("  FAIL: the eave is not level"); ok = false; }

  // ── 5. FACADE ORDER UNDER FLIP ────────────────────────────────────────────
  //
  // A window at t=0.2 and a door at t=0.5 on the same side: the window is on the
  // outside observer's LEFT, before AND after a flip.  Read it GEOMETRICALLY — reading
  // the stored t back is a tautology, and taking `outward` from the endpoint order is
  // the thing under test, so a broken rule would supply its own definition of outward.
  println("");
  println("5. FACADE ORDER UNDER FLIP — window t=0.2 stays left of door t=0.5");
  rev = 0;
  for fn2 in 0..6 {
    for fs in 0..4 {
      s0 = facade_sign(plan_new(0, 0, 5, 4, fn2, false), fs);
      s1 = facade_sign(plan_new(0, 0, 5, 4, fn2, true), fs);
      if s0 * s1 <= 0.0 { rev = rev + 1; }
    }
  }
  println("   facade reversed on {rev} of 24 (6 rot x 4 sides)");
  if rev != 0 { println("  FAIL: the facade reading flipped"); ok = false; }

  // ── 6. THE 12, AS PICTURES ────────────────────────────────────────────────
  println("");
  println("6. THE 12 — floor (.), wall edge count per orientation, door edge (D)");
  for pn in 0..6 {
    for pmi in 0..2 {
      pm = pmi == 1;
      pp = plan_new(0, 0, 5, 4, pn, pm);
      pc = hexset_chunk(Q0, R0, GW, GH);
      pt = labels_new(Q0, R0, GW, GH);
      pe = edgeset_new(Q0, R0, GW, GH);
      draw_floor(pp, pc, pt, FLOOR_BOARD);
      draw_walls(pc, pe, WALL_COTTAGE);
      dn = place_opening(pp, pc, pe, 3, 0.5, 1, OPEN_DOOR);
      println("   rot {pn} mir {pm}: floor {hexset_count(pc)}"
              + "  edges {edgeset_count_all(pe)}  door {dn}");
    }
  }

  // ── 7. THE HEX EDGES THEMSELVES ───────────────────────────────────────────
  //
  // A thin wall is not a line — it is a STRIP OF HEX EDGES, and a straight run of hex
  // boundary alternates between exactly TWO of the three edge axes.  That is why the run
  // is longer than the wall: each edge is turned +/-30 degrees off the wall line, so the
  // run is 1/cos(30) = 2/sqrt(3) = 15.47% longer, exactly, at every size.
  println("");
  println("7. HEX EDGES — the strips a thin wall is made of (rot 0)");
  println("   side  edges   run      wall     ratio   axis0 axis1 axis2");
  for ms in 0..4 {
    sr = side_edges(base, cells, ms);
    ne = side_run_len(sr);
    a0 = 0;
    a1 = 0;
    a2 = 0;
    for ei in 0..ne {
      ax = edge_axis(sr.sr_qa[ei] ?? 0, sr.sr_ra[ei] ?? 0,
                     sr.sr_qb[ei] ?? 0, sr.sr_rb[ei] ?? 0);
      if ax == 0 { a0 = a0 + 1; } else if ax == 1 { a1 = a1 + 1; } else { a2 = a2 + 1; }
    }
    nominal = 4.0 * 1.5;
    if ms == 1 || ms == 3 { nominal = 5.0 * 1.5; }
    run = (ne as float) * 0.866;
    used = 0;
    if a0 > 0 { used = used + 1; }
    if a1 > 0 { used = used + 1; }
    if a2 > 0 { used = used + 1; }
    ratio = run / nominal ?? 0.0;
    // A rectangle has two side families and the lattice has line directions at
    // 0/60/120 degrees, so only ONE family can align with them.  The two behave
    // differently and both overheads are exact:
    //   ZIGZAG    (side perpendicular to a lattice line)  2 axes,  2/sqrt(3) = 1.1547
    //   STAIRCASE (side along one)                        3 axes,  3*sqrt(3)/4 = 1.2990
    want_axes = 3;
    want_ratio = 1.29903810567;
    kind = "staircase";
    if ms == 1 || ms == 3 { want_axes = 2; want_ratio = 1.15470053838; kind = "zigzag   "; }
    println("    {ms}     {ne:>3}   {run:5.2} m  {nominal:5.2} m  {ratio:5.3}"
            + "   {a0:>4}  {a1:>4}  {a2:>4}   {used} axes  {kind}");
    if used != want_axes {
      println("  FAIL: side {ms} uses {used} hex axes, expected {want_axes}"); ok = false;
    }
    if fabs2(ratio - want_ratio) > 0.001 {
      println("  FAIL: side {ms} run overhead {ratio} != {want_ratio}"); ok = false;
    }
  }
  println("   the two overheads are exact: 2/sqrt(3) = 1.15470, 3*sqrt(3)/4 = 1.29904");

  // Across the 12: the per-side edge counts must be IDENTICAL, and the axis histogram a
  // permutation.  Same house, turned — so it may use different axes, never a different
  // number of edges.
  println("");
  println("   across the 12 orientations: per-side edge counts and total run");
  base_sig = "";
  cmp_bad = 0;
  for hn in 0..6 {
    for hmi in 0..2 {
      hm = hmi == 1;
      hp = plan_new(0, 0, 5, 4, hn, hm);
      hc = hexset_chunk(Q0, R0, GW, GH);
      ht = labels_new(Q0, R0, GW, GH);
      he = edgeset_new(Q0, R0, GW, GH);
      draw_floor(hp, hc, ht, FLOOR_BOARD);
      draw_walls(hc, he, WALL_COTTAGE);
      sig = "";
      tot = 0;
      hx0 = 0;
      hx1 = 0;
      hx2 = 0;
      for hs in 0..4 {
        hr2 = side_edges(hp, hc, hs);
        hn2 = side_run_len(hr2);
        sig += "{hn2} ";
        tot = tot + hn2;
        for hi in 0..hn2 {
          hax = edge_axis(hr2.sr_qa[hi] ?? 0, hr2.sr_ra[hi] ?? 0,
                          hr2.sr_qb[hi] ?? 0, hr2.sr_rb[hi] ?? 0);
          if hax == 0 { hx0 = hx0 + 1; } else if hax == 1 { hx1 = hx1 + 1; } else { hx2 = hx2 + 1; }
        }
      }
      if hn == 0 && !hm { base_sig = sig; }
      flag = "";
      if sig != base_sig { flag = "   <- DIFFERENT WALL"; cmp_bad = cmp_bad + 1; }
      println("   rot {hn} mir {hm}  sides [{sig}] = {tot} edges"
              + "   axes {hx0}/{hx1}/{hx2}   run {(tot as float) * 0.866:5.2} m{flag}");
    }
  }
  if cmp_bad != 0 {
    println("  FAIL: {cmp_bad} of 12 orientations carry a different wall"); ok = false;
  }

  if ok { println("=== HOUSE OK ==="); }
  else { println("=== house test FAILED ==="); }
}

// Which of the three hex edge axes this boundary edge lies on.  Classified from the
// centre-to-centre vector (the edge is perpendicular to it), so it does not depend on
// the neighbour-direction numbering or on row parity.
fn edge_axis(qa: integer, ra: integer, qb: integer, rb: integer) -> integer {
  dx = cell_x(qb, rb) - cell_x(qa, ra);
  dy = cell_y(qb, rb) - cell_y(qa, ra);
  if fabs2(dy) < 0.1 { return 0; }
  if dx * dy > 0.0 { return 1; }
  2
}

// The signed left-of-ness of the window relative to the door, in the OUTWARD frame.
fn facade_sign(p: Plan, side: integer) -> float {
  (nx, ny) = plan_side_normal(p, side);
  lx = ny;
  ly = -nx;
  (wx, wy) = plan_side_point(p, side, 0.2);
  (dx2, dy2) = plan_side_point(p, side, 0.5);
  (wx - dx2) * lx + (wy - dy2) * ly
}

// Is the mirror of an index-space 5x5 rectangle any index-space rectangle?
fn index_rect_mirror_closed() -> boolean {
  for y0 in 0..2 {
    found = false;
    for x0 in -9..10 {
      same = true;
      for ar in 0..5 {
        for aq in 0..5 {
          (mq, mr) = cell_mirror(-2 + aq, y0 + ar);
          inside = mq >= x0 && mq < x0 + 5 && mr >= y0 && mr < y0 + 5;
          if !inside { same = false; }
        }
      }
      if same { found = true; }
    }
    if !found { return false; }
  }
  true
}

// 0 if the oriented house equals the base house moved by (n, m), in cells AND edges.
fn compare_moved(bc: HexSet, be: EdgeSet, gc: HexSet, ge: EdgeSet,
                 n: integer, m: boolean) -> integer {
  diff = 0;
  seen = 0;
  for br in R0..R0 + GH {
    for bq in Q0..Q0 + GW {
      if hexset_get(bc, bq, br) {
        seen = seen + 1;
        tq = move_q(bq, br, n, m);
        tr = move_r(bq, br, n, m);
        if !hexset_get(gc, tq, tr) { diff = diff + 1; }
        for bd in 0..6 {
          xq = nb_q(bq, br, bd);
          xr = nb_r(bq, br, bd);
          if edge_mat(be, bq, br, xq, xr) != 0 {
            uq = move_q(xq, xr, n, m);
            ur = move_r(xq, xr, n, m);
            if edge_mat(ge, tq, tr, uq, ur) == 0 { diff = diff + 1; }
          }
        }
      }
    }
  }
  if hexset_count(gc) != seen { diff = diff + 1; }
  diff
}

// The massing as a picture: # where the cell owns a boundary edge, . inside.
fn print_plan(s: HexSet) {
  for pr in R0..R0 + GH {
    line = "";
    any = false;
    for pq in Q0..Q0 + GW {
      if hexset_get(s, pq, pr) {
        any = true;
        rim = false;
        for pd in 0..6 {
          if !hexset_get(s, nb_q(pq, pr, pd), nb_r(pq, pr, pd)) { rim = true; }
        }
        if rim { line += "#   "; } else { line += ".   "; }
      } else {
        if any { line += "    "; }
      }
    }
    if any {
      pad = "";
      if (pr & 1) != 0 { pad = "  "; }
      println("   {pad}{line}");
    }
  }
}
